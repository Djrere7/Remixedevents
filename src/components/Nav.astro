---
import Logo from './Logo.astro';
import { nav, site } from '../data/site';
const path = Astro.url.pathname;
const isActive = (href: string) => path === href || (href !== '/' && path.startsWith(href));
const { dark = false } = Astro.props;
---

<header class="nav" data-nav data-hero={dark ? 'dark' : undefined}>
  <div class="container wide nav-inner">
    <a href="/" class="nav-brand" aria-label="REmixed Events — home">
      <Logo height={52} />
    </a>

    <nav class="nav-links" aria-label="Primary">
      {nav.map((item) => (
        item.children ? (
          <div class="nav-item has-dropdown">
            <a href={item.href} class:list={['nav-link', { active: isActive(item.href) }]}>
              {item.label}<span class="nav-caret" aria-hidden="true">▾</span>
            </a>
            <div class="nav-dropdown">
              {item.children.map((c) => <a href={c.href} class="nav-drop-link">{c.label}</a>)}
            </div>
          </div>
        ) : (
          <a href={item.href} class:list={['nav-link', { active: isActive(item.href) }]}>
            {item.label}
          </a>
        )
      ))}
    </nav>

    <div class="nav-cta">
      <a href={site.calendly} target="_blank" rel="noopener" class="btn btn-primary nav-quote">Book a Call <span class="arrow">→</span></a>
    </div>

    <button class="nav-burger" aria-label="Open menu" aria-expanded="false" data-burger>
      <span></span><span></span>
    </button>
  </div>

  <!-- Mobile sheet -->
  <div class="nav-sheet" data-sheet hidden>
    <nav class="nav-sheet-links" aria-label="Mobile">
      {nav.map((item) => (
        <Fragment>
          <a href={item.href} class="nav-sheet-link">{item.label}</a>
          {item.children && item.children.map((c) => (
            <a href={c.href} class="nav-sheet-sub">{c.label}</a>
          ))}
        </Fragment>
      ))}
      <a href={site.calendly} target="_blank" rel="noopener" class="btn btn-primary btn-lg nav-sheet-cta">Book a Call <span class="arrow">→</span></a>
    </nav>
  </div>
</header>

<style>
  .nav {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 100;
    transition: background 0.4s var(--ease), backdrop-filter 0.4s var(--ease), border-color 0.4s var(--ease);
    border-bottom: 1px solid transparent;
  }
  .nav[data-scrolled] {
    background: rgba(255, 255, 255, 0.78);
    backdrop-filter: blur(18px) saturate(1.4);
    border-bottom-color: var(--line);
    box-shadow: 0 8px 30px -22px rgba(40, 16, 80, 0.4);
  }

  /* Dark-hero pages: keep the nav readable over the video before it becomes a
     solid bar on scroll. A soft top scrim + white text guarantees contrast. */
  .nav[data-hero='dark']:not([data-scrolled])::before {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(180deg, rgba(8, 4, 15, 0.55) 0%, rgba(8, 4, 15, 0.12) 70%, transparent 100%);
    pointer-events: none;
    z-index: -1;
  }
  .nav[data-hero='dark']:not([data-scrolled]) .nav-link { color: #fff; text-shadow: 0 1px 12px rgba(0, 0, 0, 0.35); }
  .nav[data-hero='dark']:not([data-scrolled]) .nav-link:hover { color: #fff; background: rgba(255, 255, 255, 0.16); }
  .nav[data-hero='dark']:not([data-scrolled]) .nav-link.active { color: #fff; }
  .nav[data-hero='dark']:not([data-scrolled]) .nav-burger { background: rgba(255, 255, 255, 0.14); border-color: rgba(255, 255, 255, 0.4); }
  .nav[data-hero='dark']:not([data-scrolled]) .nav-burger span { background: #fff; }
  .nav-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1.5rem;
    height: 78px;
  }
  .nav-links {
    display: flex;
    align-items: center;
    gap: 0.7rem;
    position: absolute;
    left: 50%;
    transform: translateX(-50%);
  }
  .nav-link {
    font-weight: 600;
    font-size: 1.05rem;
    color: var(--text);
    padding: 0.6rem 1.1rem;
    border-radius: 999px;
    transition: color 0.3s var(--ease), background 0.3s var(--ease);
    position: relative;
  }
  .nav-link:hover { color: var(--violet); background: rgba(123, 47, 247, 0.09); }
  .nav-link.active { color: var(--violet); font-weight: 700; }

  /* Experiences dropdown */
  .nav-item { position: relative; display: inline-flex; }
  .nav-caret { font-size: 0.62em; margin-left: 0.35em; opacity: 0.65; vertical-align: middle; }
  .nav-dropdown {
    position: absolute;
    top: 100%; left: 50%;
    transform: translateX(-50%) translateY(6px);
    min-width: 250px;
    background: #fff;
    border: 1px solid var(--line);
    border-radius: 16px;
    box-shadow: 0 24px 55px -22px rgba(40, 16, 80, 0.4);
    padding: 0.5rem;
    display: grid;
    gap: 0.1rem;
    opacity: 0; visibility: hidden;
    transition: opacity 0.25s var(--ease), transform 0.25s var(--ease), visibility 0.25s;
    z-index: 120;
  }
  .nav-dropdown::before { content: ""; position: absolute; top: -12px; left: 0; right: 0; height: 12px; }
  .nav-item.has-dropdown:hover .nav-dropdown,
  .nav-item.has-dropdown:focus-within .nav-dropdown {
    opacity: 1; visibility: visible; transform: translateX(-50%) translateY(4px);
  }
  .nav-drop-link {
    padding: 0.65rem 0.9rem;
    border-radius: 10px;
    font-weight: 600;
    font-size: 0.98rem;
    color: var(--text);
    white-space: nowrap;
    transition: color 0.2s var(--ease), background 0.2s var(--ease);
  }
  .nav-drop-link:hover { background: rgba(123, 47, 247, 0.09); color: var(--violet); }
  .nav-link.active::after {
    content: "";
    position: absolute;
    bottom: 0.1rem;
    left: 50%;
    transform: translateX(-50%);
    width: 22px; height: 3px;
    border-radius: 3px;
    background: var(--grad-soft);
  }
  .nav-cta { display: flex; align-items: center; }
  .nav-quote { --pad-y: 0.72rem; --pad-x: 1.4rem; font-size: 0.98rem; }

  .nav-burger {
    display: none;
    flex-direction: column;
    gap: 6px;
    width: 44px; height: 44px;
    align-items: center;
    justify-content: center;
    background: rgba(26, 11, 56, 0.04);
    border: 1px solid var(--line-strong);
    border-radius: 12px;
  }
  .nav-burger span {
    width: 20px; height: 2px; border-radius: 2px;
    background: var(--text);
    transition: transform 0.35s var(--ease), opacity 0.25s var(--ease);
  }
  .nav-burger[aria-expanded='true'] span:first-child { transform: translateY(4px) rotate(45deg); }
  .nav-burger[aria-expanded='true'] span:last-child { transform: translateY(-4px) rotate(-45deg); }

  /* When the mobile menu is open, force a solid, readable bar (even over a
     dark hero) so the burger and sheet never blend into the media. */
  .nav[data-menu-open] { background: #fbf9ff; border-bottom-color: var(--line); }
  .nav[data-menu-open] .nav-burger { background: rgba(26, 11, 56, 0.04); border-color: var(--line-strong); }
  .nav[data-menu-open] .nav-burger span { background: var(--text); }

  .nav-sheet {
    position: fixed;
    inset: 78px 0 0 0;
    z-index: 190;
    background: #fbf9ff;
    backdrop-filter: blur(20px);
    padding: 1.5rem var(--gutter) 3rem;
    overflow-y: auto;
    -webkit-overflow-scrolling: touch;
    overscroll-behavior: contain;
    animation: sheet 0.4s var(--ease);
  }
  @keyframes sheet { from { opacity: 0; transform: translateY(-8px); } to { opacity: 1; transform: none; } }
  .nav-sheet-links { display: flex; flex-direction: column; gap: 0.1rem; }
  .nav-sheet-link {
    font-family: var(--font-display);
    font-size: 1.7rem;
    font-weight: 600;
    letter-spacing: -0.03em;
    padding: 0.85rem 0;
    border-bottom: 1px solid var(--line);
  }
  .nav-sheet-sub {
    font-family: var(--font-sans);
    font-size: 1.05rem;
    font-weight: 500;
    color: var(--text-dim);
    padding: 0.55rem 0 0.55rem 1.1rem;
    border-left: 2px solid var(--line-strong);
    margin-left: 0.2rem;
  }
  .nav-sheet-sub:hover { color: var(--violet); }
  .nav-sheet-cta { margin-top: 1.5rem; }

  @media (max-width: 940px) {
    .nav-links, .nav-cta { display: none; }
    .nav-burger { display: flex; }
  }
</style>

<script>
  const header = document.querySelector('[data-nav]');
  const onScroll = () => {
    if (!header) return;
    if (window.scrollY > 12) header.setAttribute('data-scrolled', '');
    else header.removeAttribute('data-scrolled');
  };
  onScroll();
  window.addEventListener('scroll', onScroll, { passive: true });

  const burger = document.querySelector('[data-burger]');
  const sheet = document.querySelector('[data-sheet]');
  const setMenu = (open: boolean) => {
    burger?.setAttribute('aria-expanded', String(open));
    if (sheet) (sheet as HTMLElement).hidden = !open;
    header?.toggleAttribute('data-menu-open', open);
    document.body.style.overflow = open ? 'hidden' : '';
  };
  burger?.addEventListener('click', () => {
    setMenu(burger.getAttribute('aria-expanded') !== 'true');
  });
  // Close after choosing a destination (including in-page anchors).
  sheet?.querySelectorAll('a').forEach((a) => a.addEventListener('click', () => setMenu(false)));
  // Close if resized up to desktop so state never gets stuck.
  window.addEventListener('resize', () => {
    if (window.innerWidth > 940) setMenu(false);
  });
</script>
