---
/**
 * Brand wordmark — the official REmixed Events logo (transparent PNG).
 * Source art lives at /public/logo.png.
 */
interface Props {
  /** pixel height of the logo */
  height?: number;
  class?: string;
}
const { height = 44, class: cls = '' } = Astro.props;
---

<img
  src="/logo.png"
  alt="REmixed Events"
  class={`logo ${cls}`}
  height={height}
  style={`height:${height}px`}
  width={height * 3}
  loading="eager"
  decoding="async"
/>

<style>
  .logo {
    width: auto;
    display: block;
    user-select: none;
  }
</style>
