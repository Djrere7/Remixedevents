---
import Logo from './Logo.astro';
import { site, nav } from '../data/site';
const year = new Date().getFullYear();
---

<footer class="footer">
  <div class="container wide">
    <div class="footer-cta card on-grad">
      <div class="footer-cta-glow glow" aria-hidden="true"></div>
      <div class="footer-cta-inner">
        <p class="kicker">Ready when you are</p>
        <h2 class="h1">Ready for a DJ company that actually <span class="font-stroke">gets it?</span></h2>
        <p class="lede">Tell us what you’re planning. We’ll help curate the female DJ entertainment, sound, style, and energy for your event.</p>
        <div class="footer-cta-actions">
          <a href={site.calendly} target="_blank" rel="noopener" class="btn btn-primary btn-lg">Schedule a Free Consultation <span class="arrow">→</span></a>
          <a href="/contact" class="btn btn-ghost btn-lg">Contact us</a>
        </div>
      </div>
    </div>

    <div class="footer-grid">
      <div class="footer-brand">
        <Logo />
        <p class="footer-mini">Not Your Ordinary DJ Company.</p>
        <p class="footer-slogan">{site.slogan}</p>
        <div class="footer-socials">
          <a href={site.socials.instagram} target="_blank" rel="noopener" aria-label="Instagram">Instagram</a>
          <a href={site.socials.facebook} target="_blank" rel="noopener" aria-label="Facebook">Facebook</a>
          <a href={site.socials.linkedin} target="_blank" rel="noopener" aria-label="LinkedIn">LinkedIn</a>
          <a href={site.socials.twitter} target="_blank" rel="noopener" aria-label="X">X</a>
        </div>
      </div>

      <nav class="footer-col" aria-label="Footer">
        <h3 class="footer-h">Explore</h3>
        {nav.map((item) => <a href={item.href}>{item.label}</a>)}
        <a href={site.calendly} target="_blank" rel="noopener">Book a Call</a>
      </nav>

      <div class="footer-col">
        <h3 class="footer-h">Connect</h3>
        <a href={`mailto:${site.email}`}>{site.email}</a>
        <a href={site.phoneHref}>{site.phone}</a>
        <span class="footer-meta">{site.address}</span>
        <span class="footer-meta">Based in Miami Beach. Serving South Florida & destination events.</span>
      </div>
    </div>

    <hr class="eased-line" />
    <div class="footer-base">
      <span>© {year} {site.legalName}. All rights reserved.</span>
      <span class="footer-tag">{site.tagline}</span>
    </div>
  </div>
</footer>

<style>
  .footer { padding-block: clamp(3rem, 2rem + 4vw, 5rem) 2.5rem; position: relative; }

  .footer-cta {
    padding: clamp(2.5rem, 1.5rem + 5vw, 5rem);
    text-align: center;
    margin-bottom: clamp(3rem, 2rem + 4vw, 5rem);
    border: 0;
    box-shadow: 0 40px 80px -36px rgba(123, 47, 247, 0.55);
  }
  .footer-cta-inner { position: relative; z-index: 1; display: grid; gap: 1.4rem; justify-items: center; }
  .footer-cta .lede { margin-inline: auto; }
  .footer-cta-glow {
    width: 70%; height: 90%;
    top: -25%; left: 15%;
    background: radial-gradient(circle, rgba(255,255,255,0.45), transparent 65%);
    opacity: 0.6;
    filter: blur(60px);
  }
  .footer-cta-actions { display: flex; gap: 0.8rem; flex-wrap: wrap; justify-content: center; margin-top: 0.5rem; }

  .footer-grid {
    display: grid;
    grid-template-columns: 1.6fr 1fr 1fr;
    gap: 2.5rem;
    padding-block: 1rem 2.5rem;
  }
  .footer-mini { font-family: var(--font-display); font-weight: 600; font-size: 1.05rem; letter-spacing: -0.01em; margin-top: 1.1rem; color: var(--text); }
  .footer-slogan { color: var(--text-dim); max-width: 40ch; margin-top: 0.6rem; font-size: 0.95rem; }
  .footer-socials { display: flex; gap: 1.2rem; margin-top: 1.5rem; flex-wrap: wrap; }
  .footer-socials a { font-size: 0.9rem; color: var(--text-mute); transition: color 0.3s var(--ease); }
  .footer-socials a:hover { color: var(--magenta); }

  .footer-col { display: flex; flex-direction: column; gap: 0.7rem; }
  .footer-h {
    font-family: var(--font-sans);
    font-size: 0.78rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--text-mute);
    font-weight: 600;
    margin-bottom: 0.4rem;
  }
  .footer-col a { color: var(--text-dim); font-size: 0.95rem; transition: color 0.3s var(--ease); width: fit-content; }
  .footer-col a:hover { color: var(--text); }
  .footer-meta { color: var(--text-mute); font-size: 0.95rem; }

  .footer-base {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 1rem;
    padding-top: 1.6rem;
    color: var(--text-mute);
    font-size: 0.85rem;
    flex-wrap: wrap;
  }
  .footer-tag { font-family: var(--font-serif); font-style: italic; letter-spacing: 0.01em; }

  @media (max-width: 760px) {
    .footer-grid { grid-template-columns: 1fr; gap: 2rem; }
  }
</style>
