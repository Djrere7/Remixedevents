---
/**
 * Responsive 16:9 YouTube embed styled to match the site's video frames
 * (gradient hairline frame, rounded corners). Privacy-enhanced (nocookie).
 */
interface Props {
  id: string;
  title?: string;
  class?: string;
}
const { id, title = 'REmixed Events video', class: cls = '' } = Astro.props;
const src = `https://www.youtube-nocookie.com/embed/${id}?rel=0&modestbranding=1&playsinline=1`;
---

<div class:list={['yt-frame', cls]} data-reveal>
  <iframe
    src={src}
    title={title}
    loading="lazy"
    allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
    referrerpolicy="strict-origin-when-cross-origin"
    allowfullscreen
  ></iframe>
</div>

<style>
  .yt-frame {
    position: relative;
    aspect-ratio: 16 / 9;
    width: 100%;
    border-radius: 24px;
    padding: 1.5px;
    background: var(--grad-soft);
    box-shadow: 0 50px 90px -50px rgba(123, 47, 247, 0.6);
  }
  .yt-frame iframe {
    position: absolute;
    inset: 1.5px;
    width: calc(100% - 3px);
    height: calc(100% - 3px);
    border: 0;
    border-radius: 23px;
    display: block;
    background: #000;
  }
</style>
