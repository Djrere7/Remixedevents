---
import Base from '../layouts/Base.astro';
import PageHeader from '../components/PageHeader.astro';
import Media from '../components/Media.astro';
import Marquee from '../components/Marquee.astro';
import { site } from '../data/site';

const capabilities = [
  { t: 'Brand activations', d: 'DJs, branded setups, music direction and content friendly moments that help your audience connect with your brand.' },
  { t: 'Conferences & summits', d: 'Walk up tracks, transitions, networking music, microphones and polished timing that keeps the event moving.' },
  { t: 'Galas & holiday parties', d: 'Elegant energy early in the night, then a packed dance floor when it is time to celebrate.' },
  { t: 'Corporate celebrations', d: 'DJs, hosts, sound, lighting and production support from one experienced team.' },
];

const whyItems = [
  'We make your job easier',
  'Clear communication',
  'Prepared & on time',
  'The right energy for the room',
  'Brand standards understood',
  'Insured & professional',
  'One experienced team',
  'Planners & agencies trust us',
];

const logos = ['Smartwater', "Raising Cane's", 'Universe Communications', 'Miami Music Week', 'We The Best', 'The Source'];

const activationImgs = [
  { src: '/img/activation-aero.jpg', alt: 'Aeropostale and Cheetos brand activation booth', aspect: '3/4' },
  { src: '/img/corporate-acc.jpg', alt: 'ACC branded activation tent', aspect: '3/4' },
  { src: '/img/dj-outdoor.jpg', alt: 'A REmixed DJ energizing an outdoor corporate crowd', aspect: '3/4' },
  { src: '/img/venue-uplights.jpg', alt: 'Uplit corporate gala stage', aspect: '3/4' },
  { src: '/img/rere-khaled.jpg', alt: 'REmixed at a high profile brand event', aspect: '3/4' },
  { src: '/img/booth-setup.jpg', alt: 'Custom branded DJ booth with uplighting', aspect: '3/4' },
];
---

<Base title="Corporate & Brand Activations" description="Polished DJ entertainment and production for brands. REmixed Events supports brand activations, corporate events, launches, conferences and galas across South Florida.">
  <PageHeader
    kicker="Corporate events & brand activations"
    title="Entertainment built for luxe brands &"
    emphasis="corporate events."
    emphasisClass="font-stroke"
    lede="For marketing agencies, event coordinators and brand teams, the entertainment cannot feel random. It has to match the audience, the message, the room and the moment. REmixed brings polished DJs, sound, lighting and production support to activations, corporate events, launches, conferences and galas. We understand the assignment: look good, sound good, stay professional and make the brand unforgettable in real life."
  >
    <div class="ph-actions" data-reveal style="--reveal-delay:200ms">
      <a href="/contact" class="btn btn-primary btn-lg">Plan your activation <span class="arrow">→</span></a>
      <a href={`mailto:${site.email}`} class="btn btn-ghost btn-lg">Talk to the team</a>
    </div>
  </PageHeader>

  <!-- CLIENT STRIP -->
  <section class="section tight clients">
    <div class="container wide">
      <p class="clients-label">Trusted by teams across industries</p>
      <div class="clients-row" data-reveal>
        {logos.map((l) => <span class="client-name">{l}</span>)}
      </div>
    </div>
  </section>

  <!-- CAPABILITIES -->
  <section class="section">
    <div class="container wide">
      <div class="sec-head">
        <div>
          <p class="kicker" data-reveal>What we bring</p>
          <h2 class="h2" data-reveal style="--reveal-delay:80ms">Entertainment built for brand moments.</h2>
        </div>
      </div>
      <div class="cap-grid">
        {capabilities.map((c, i) => (
          <article class="card card-glow cap" data-reveal style={`--reveal-delay:${i * 70}ms`}>
            <span class="cap-mark gtext" aria-hidden="true">✦</span>
            <h3 class="h3">{c.t}</h3>
            <p>{c.d}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- CASE STUDY VIDEO -->
  <section class="section tight">
    <div class="container wide cs-grid">
      <div class="cs-copy">
        <p class="kicker" data-reveal>Inside a REmixed activation</p>
        <h2 class="h2" data-reveal style="--reveal-delay:80ms">Watch a brand <span class="font-stroke gtext">come alive.</span></h2>
        <p class="lede" data-reveal style="--reveal-delay:140ms">From load in to last call, see how we turn a footprint into a feeling your audience remembers.</p>
        <a href="/contact" class="btn btn-primary btn-lg" data-reveal style="--reveal-delay:200ms">Start your brief <span class="arrow">→</span></a>
      </div>
      <Media type="video" src="/video/reel.mp4" poster="/video/reel-poster.jpg" aspect="16/9" feather={false} class="cs-video" />
    </div>
  </section>

  <!-- ACTIVATION GALLERY -->
  <section class="section tight">
    <div class="container wide">
      <div class="sec-head">
        <div>
          <p class="kicker" data-reveal>A little look around</p>
          <h2 class="h2" data-reveal style="--reveal-delay:80ms">Caught in the moment.</h2>
        </div>
      </div>
      <div class="act-gallery">
        {activationImgs.map((g) => (
          <Media src={g.src} alt={g.alt} aspect={g.aspect} />
        ))}
      </div>
    </div>
  </section>

  <!-- WHY (scrolling marquee) -->
  <section class="section tight section-light">
    <div class="container wide">
      <div class="why-head">
        <p class="kicker" data-reveal>Why brands book us</p>
        <h2 class="h1" data-reveal style="--reveal-delay:80ms">We make your job <span class="font-stroke gtext">easier.</span></h2>
      </div>
    </div>
    <Marquee items={whyItems} speed={34} />
  </section>

  <!-- VIDEO QUOTE -->
  <section class="quote-video">
    <div class="qv-media" aria-hidden="true">
      <video autoplay muted loop playsinline preload="metadata" poster="/video/reel-poster.jpg">
        <source src="/video/reel.mp4" type="video/mp4" />
      </video>
      <div class="qv-scrim"></div>
    </div>
    <div class="container wide qv-inner">
      <p class="qv-quote font-stroke" data-reveal>“You understood exactly what we wanted.”</p>
      <p class="qv-cite" data-reveal style="--reveal-delay:120ms">The compliment we hear most, from the planners and brands we work with.</p>
    </div>
  </section>
</Base>

<style>
  .ph-actions { display: flex; gap: 0.8rem; flex-wrap: wrap; margin-top: 2rem; }

  .clients { border-block: 1px solid var(--line); }
  .clients-label { text-align: center; font-size: 0.74rem; letter-spacing: 0.24em; text-transform: uppercase; color: var(--text-mute); margin-bottom: 1.4rem; }
  .clients-row { display: flex; flex-wrap: wrap; gap: 1.2rem 2.4rem; justify-content: center; }
  .client-name { font-family: var(--font-display); font-weight: 500; font-size: clamp(1rem, 0.9rem + 0.5vw, 1.4rem); color: var(--text-dim); opacity: 0.85; }

  .sec-head { margin-bottom: clamp(2rem, 1.5rem + 2vw, 3rem); }
  .sec-head > div { display: grid; gap: 0.9rem; }

  .cap-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 1.2rem; }
  .cap { padding: clamp(1.6rem, 1.2rem + 1.5vw, 2.4rem); display: grid; gap: 0.9rem; align-content: start; }
  .cap-mark { font-size: 1.3rem; }
  .cap p { color: var(--text-dim); }
  @media (max-width: 760px) { .cap-grid { grid-template-columns: 1fr; } }

  .why-head { display: grid; gap: 0.9rem; max-width: 22ch; margin-bottom: clamp(2rem, 1.5rem + 2vw, 3rem); }
  .why-head .h1 { max-width: 14ch; }
  .why-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 1rem; }
  .why { padding: 1.7rem 1.5rem; display: grid; gap: 0.5rem; align-content: start; }
  .why-t { font-family: var(--font-display); font-size: 1.15rem; font-weight: 600; }
  .why-d { color: var(--cream-dim); font-size: 0.92rem; }
  @media (max-width: 880px) { .why-grid { grid-template-columns: 1fr 1fr; } }
  @media (max-width: 480px) { .why-grid { grid-template-columns: 1fr; } }

  .big-quote { max-width: 26ch; margin: 0 auto; text-align: center; display: grid; gap: 1.4rem; }
  .big-quote-text { font-size: clamp(1.6rem, 1.1rem + 2.6vw, 3rem); line-height: 1.18; letter-spacing: -0.02em; }
  .big-quote-cite { color: var(--text-dim); font-size: 0.95rem; }
  .big-quote-cite .gtext { font-weight: 600; }

  .cs-grid { display: grid; grid-template-columns: 0.85fr 1.15fr; gap: clamp(1.5rem, 1rem + 3vw, 3.5rem); align-items: center; }
  .cs-copy { display: grid; gap: 1.2rem; justify-items: start; }
  @media (max-width: 820px) { .cs-grid { grid-template-columns: 1fr; } }

  .act-gallery { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1.1rem; }
  @media (max-width: 820px) { .act-gallery { grid-template-columns: 1fr 1fr; } }

  /* Video-backed quote */
  .quote-video { position: relative; min-height: clamp(360px, 55vh, 560px); display: flex; align-items: center; overflow: hidden; isolation: isolate; }
  .qv-media { position: absolute; inset: 0; z-index: 0; }
  .qv-media video { width: 100%; height: 100%; object-fit: cover; }
  .qv-scrim { position: absolute; inset: 0; background: linear-gradient(180deg, rgba(8,4,15,0.55), rgba(8,4,15,0.42) 45%, rgba(8,4,15,0.7)); }
  .qv-inner { position: relative; z-index: 1; text-align: center; display: grid; gap: 1rem; justify-items: center; padding-block: clamp(3rem, 2rem + 4vw, 5rem); }
  .qv-quote { color: #fff; font-size: clamp(2rem, 1.3rem + 4vw, 4.4rem); line-height: 1.15; max-width: 20ch; text-shadow: 0 2px 24px rgba(0,0,0,0.4); }
  .qv-cite { color: rgba(255,255,255,0.85); font-size: 0.95rem; letter-spacing: 0.02em; }
</style>
