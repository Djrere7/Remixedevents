---
import Base from '../layouts/Base.astro';
import PageHeader from '../components/PageHeader.astro';
import Marquee from '../components/Marquee.astro';
import Media from '../components/Media.astro';
import { awards, stats, site } from '../data/site';

const values = [
  { t: 'Female DJs at the forefront', d: 'We proudly specialize in female DJs and bring a fresh, stylish energy to the event industry.' },
  { t: 'White glove service', d: 'We are organized, communicative, prepared and detail focused from inquiry to final song.' },
  { t: 'Music that feels personal', d: 'No copy and paste playlists. We curate around your crowd and culture, and we know when to keep it polished, build the room and turn the moment up.' },
];
---

<Base title="About" description="REmixed Events is South Florida’s female DJ entertainment company. Meet the team behind stylish, personal entertainment for weddings, brands, schools and celebrations.">
  <PageHeader
    kicker="Our story"
    title="The female DJ company that"
    emphasis="gets it."
    emphasisClass="font-stroke"
    lede="REmixed Events was created because the right DJ should not be hard to find. For years, DJ ReRe was the rare kind of DJ clients were always looking for."
  />

  <!-- STORY -->
  <section class="section tight">
    <div class="container wide story-grid">
      <div class="story-portrait" data-reveal>
        <Media src="/img/rere-portrait.jpg" alt="DJ ReRe, founder of REmixed Events" aspect="4/5" eager={true} />
      </div>

      <div class="story-copy" data-reveal style="--reveal-delay:120ms">
        <p class="story-lead serif">“We are the party girls and the professionals.”</p>
        <p>
          Professional. Stylish. High energy. Easy to work with. Amazing behind the decks. Completely in tune
          with the room. She could read a crowd, respect a timeline, match the aesthetic, communicate with
          vendors and still bring the kind of music that made people say, <strong>“Where did you find her?”</strong>
        </p>
        <p>
          She was not just showing up to play music. She was showing up to understand the moment. That became
          the heartbeat of REmixed Events. Today, REmixed is a South Florida female DJ entertainment company
          built for weddings, brands, schools and celebrations that deserve a fresh kind of energy.
        </p>
        <p>
          We know the people planning these moments are carrying a lot. The music, the timing, the photos, the
          guests, the announcements and the “please do not make this awkward” moments. We get it, because we
          have been there. We are the calm before the party and the energy once it starts. <em>We are REmixed Events.</em>
        </p>
      </div>
    </div>
  </section>

  <!-- STATS -->
  <section class="section tight">
    <div class="container wide">
      <div class="about-stats">
        {stats.map((s, i) => (
          <div class="astat" data-reveal style={`--reveal-delay:${i * 80}ms`}>
            <span class="astat-v gtext">{s.value}</span>
            <span class="astat-l">{s.label}</span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- INTRO VIDEO -->
  <section class="section tight">
    <div class="container wide">
      <div class="meet-head">
        <p class="kicker center" data-reveal style="display:flex;justify-content:center">In her own words</p>
        <h2 class="h2 center" data-reveal style="--reveal-delay:80ms">Meet the woman <span class="font-stroke gtext">behind the booth.</span></h2>
      </div>
      <Media type="video" src="/video/dj.mp4" poster="/video/dj-poster.jpg" aspect="16/9" feather={false} class="meet-video" />
    </div>
  </section>

  <!-- VALUES -->
  <section class="section">
    <div class="container wide">
      <div class="sec-head">
        <div>
          <p class="kicker" data-reveal>What we stand for</p>
          <h2 class="h2" data-reveal style="--reveal-delay:80ms">Style, skill and a whole lot of <span class="font-stroke gtext">care.</span></h2>
        </div>
      </div>
      <div class="val-grid">
        {values.map((v, i) => (
          <article class="card card-glow val" data-reveal style={`--reveal-delay:${i * 80}ms`}>
            <span class="val-mark gtext" aria-hidden="true">✦</span>
            <h3 class="h3">{v.t}</h3>
            <p>{v.d}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- MIXHER -->
  <section class="section">
    <div class="container wide">
      <div class="mixher card on-grad" data-reveal>
        <div class="mixher-glow glow" aria-hidden="true"></div>
        <div class="mixher-inner">
          <p class="kicker">Giving back</p>
          <h2 class="h1">
            <span class="gtext">MixHer,</span> <span class="font-stroke">handing women the mic.</span>
          </h2>
          <p class="lede">
            MixHer is our community created to mentor, uplift and create more space for female DJs and artists.
            It is part of the REmixed heartbeat. When you book REmixed, you are supporting a company that believes
            women belong behind the decks, on the mic, in the room and at the center of the sound.
          </p>
          <a href={site.mixherUrl} target="_blank" rel="noopener" class="btn btn-primary btn-lg">Visit MixHer <span class="arrow">→</span></a>
        </div>
      </div>
    </div>
  </section>

  <section class="section tight awards-band">
    <Marquee items={awards} speed={30} />
  </section>
</Base>

<style>
  .story-grid { display: grid; grid-template-columns: 0.8fr 1.2fr; gap: clamp(2rem, 1rem + 4vw, 4rem); align-items: start; }
  .story-portrait { position: sticky; top: 100px; }

  .story-copy { display: grid; gap: 1.2rem; }

  .meet-head { text-align: center; display: grid; gap: 0.9rem; justify-items: center; max-width: 30ch; margin: 0 auto clamp(1.6rem, 1rem + 2vw, 2.4rem); }
  :global(.meet-video) { max-width: 960px; margin-inline: auto; box-shadow: 0 50px 90px -50px rgba(123, 47, 247, 0.55); }
  .story-lead { font-size: clamp(1.4rem, 1.1rem + 1.6vw, 2.1rem); line-height: 1.25; letter-spacing: -0.01em; margin-bottom: 0.4rem; }
  .story-copy p { color: var(--text-dim); }
  .story-copy strong { color: var(--text); font-weight: 600; }
  @media (max-width: 820px) { .story-grid { grid-template-columns: 1fr; } .story-portrait { max-width: 360px; position: static; } }

  .about-stats { display: grid; grid-template-columns: repeat(4, 1fr); gap: 1rem; border-block: 1px solid var(--line); padding-block: clamp(1.8rem, 1.2rem + 2vw, 2.6rem); }
  .astat { display: grid; gap: 0.3rem; text-align: center; }
  .astat-v { font-family: var(--font-display); font-weight: 700; font-size: clamp(2.2rem, 1.6rem + 2.4vw, 3.4rem); letter-spacing: -0.03em; line-height: 1; }
  .astat-l { color: var(--text-dim); font-size: 0.9rem; }
  @media (max-width: 620px) { .about-stats { grid-template-columns: 1fr 1fr; gap: 1.6rem; } }

  .sec-head { margin-bottom: clamp(2rem, 1.5rem + 2vw, 3rem); }
  .sec-head > div { display: grid; gap: 0.9rem; }

  .val-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1.2rem; }
  .val { padding: clamp(1.6rem, 1.2rem + 1.5vw, 2.2rem); display: grid; gap: 0.8rem; align-content: start; }
  .val-mark { font-size: 1.3rem; }
  .val p { color: var(--text-dim); }
  @media (max-width: 820px) { .val-grid { grid-template-columns: 1fr; } }

  .mixher { padding: clamp(2.2rem, 1.5rem + 4vw, 4.5rem); background: var(--grad); border: 0; overflow: hidden; box-shadow: 0 40px 80px -36px rgba(123, 47, 247, 0.55); }
  .mixher-glow { width: 55%; height: 130%; top: -15%; right: -8%; background: radial-gradient(circle, rgba(255,255,255,0.4), transparent 65%); opacity: 0.55; filter: blur(60px); }
  .mixher-inner { position: relative; z-index: 1; display: grid; gap: 1.3rem; max-width: 640px; }
  .mixher-inner .h1 { max-width: 16ch; }
  .awards-band { border-top: 1px solid var(--line); }
</style>
