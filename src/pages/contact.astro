---
import Base from '../layouts/Base.astro';
import { site, awards } from '../data/site';

const steps = [
  { n: '01', t: 'Tell us the vision', d: 'Share your date, venue and the feeling you’re after. The more detail, the better the proposal.' },
  { n: '02', t: 'Get a tailored quote', d: 'We’ll come back fast with a curated package and transparent pricing, no templated guesswork.' },
  { n: '03', t: 'Lock it in', d: 'Sign, secure your date and hand off the details. We produce the rest, start to finish.' },
];
---

<Base title="Request a Quote" description="Request a quote from REmixed Events, South Florida’s female DJ entertainment company for weddings, brands, schools, corporate events and private celebrations.">
  <section class="ct-hero">
    <div class="ct-glow glow" aria-hidden="true"></div>
    <div class="container wide ct-grid">
      <div class="ct-copy">
        <p class="kicker" data-reveal>Let’s talk</p>
        <h1 class="h1" data-reveal style="--reveal-delay:80ms">
          Tell us what you are planning. We already know it <span class="font-stroke gtext">matters.</span>
        </h1>
        <p class="lede" data-reveal style="--reveal-delay:140ms">
          Whether you are planning a wedding, brand activation, school event, corporate celebration, birthday or
          private party, we would love to hear about it. Tell us the date, location, guest count and the feeling
          you want in the room, and we’ll help curate the right female DJ, production and experience to match.
          No basic playlists. No awkward energy. Just a team that gets it.
        </p>

        <ol class="ct-steps" data-reveal style="--reveal-delay:200ms">
          {steps.map((s) => (
            <li class="ct-step">
              <span class="ct-step-n gtext">{s.n}</span>
              <div>
                <h3 class="ct-step-t">{s.t}</h3>
                <p class="ct-step-d">{s.d}</p>
              </div>
            </li>
          ))}
        </ol>

        <div class="ct-direct" data-reveal style="--reveal-delay:260ms">
          <a href={`mailto:${site.email}`} class="tlink">{site.email} <span class="arrow">→</span></a>
          <a href={site.phoneHref} class="tlink">{site.phone} <span class="arrow">→</span></a>
        </div>

        <!-- quick email capture -->
        <form class="ct-capture" data-capture data-reveal style="--reveal-delay:300ms">
          <label class="sr-only" for="cap-email">Your email</label>
          <input id="cap-email" type="email" name="email" required placeholder="Your email, we’ll reach out" />
          <button type="submit" class="btn btn-primary">Say hello <span class="arrow">→</span></button>
        </form>

        <ul class="ct-badges" data-reveal style="--reveal-delay:320ms">
          {awards.slice(0, 3).map((a) => <li class="chip">✦ {a}</li>)}
        </ul>
      </div>

      <div class="ct-form-col" data-reveal style="--reveal-delay:160ms">
        <div class="ct-form-frame">
          <iframe
            id="quote-iframe"
            src="/quote-form.html"
            title="Request a quote"
            loading="eager"
            scrolling="no"
            style="width:100%;border:0;height:1500px;"
          ></iframe>
        </div>
        <p class="ct-secure">🔒 Submissions go straight to the REmixed Events team. We never share your details.</p>
      </div>
    </div>
  </section>

  <!-- FIND US + MAP -->
  <section class="section tight ct-map-section">
    <div class="container wide ct-map-grid">
      <div class="ct-map-copy">
        <p class="kicker" data-reveal>Find us</p>
        <h2 class="h2" data-reveal style="--reveal-delay:80ms">Based in <span class="font-stroke gtext">Miami Beach.</span></h2>
        <p class="lede" data-reveal style="--reveal-delay:140ms">Proudly serving weddings, brands, schools and celebrations across South Florida and beyond.</p>
        <ul class="ct-details" data-reveal style="--reveal-delay:200ms">
          <li><span class="ct-d-k">Studio</span><span>{site.address}</span></li>
          <li><span class="ct-d-k">Email</span><a href={`mailto:${site.email}`}>{site.email}</a></li>
          <li><span class="ct-d-k">Call</span><a href={site.phoneHref}>{site.phone}</a></li>
          <li><span class="ct-d-k">Google</span><a href={site.reviewUrl} target="_blank" rel="noopener">Rated {site.googleRating}★ — read reviews</a></li>
        </ul>
      </div>
      <div class="ct-map" data-reveal style="--reveal-delay:120ms">
        <iframe
          title="REmixed Events location map"
          src={`https://www.google.com/maps?q=${encodeURIComponent(site.mapQuery)}&output=embed`}
          loading="lazy"
          referrerpolicy="no-referrer-when-downgrade"
        ></iframe>
      </div>
    </div>
  </section>
</Base>

<style>
  .ct-hero { position: relative; padding-top: 130px; padding-bottom: 5rem; overflow: hidden; }
  .ct-glow { width: 50vw; height: 50vw; max-width: 620px; max-height: 620px; top: -12%; left: -10%; background: var(--grad-radial); opacity: 0.34; }
  .ct-grid {
    position: relative; z-index: 1;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: clamp(2rem, 1rem + 4vw, 4.5rem);
    align-items: start;
  }
  .ct-copy { display: grid; gap: 1.4rem; position: sticky; top: 100px; }
  .ct-steps { display: grid; gap: 1.1rem; margin-top: 0.6rem; }
  .ct-step { display: flex; gap: 1rem; align-items: flex-start; }
  .ct-step-n { font-family: var(--font-display); font-weight: 700; font-size: 1.4rem; letter-spacing: -0.02em; flex-shrink: 0; min-width: 2.2rem; }
  .ct-step-t { font-family: var(--font-display); font-size: 1.1rem; font-weight: 600; letter-spacing: -0.01em; }
  .ct-step-d { color: var(--text-dim); font-size: 0.95rem; margin-top: 0.2rem; }
  .ct-direct { display: flex; align-items: center; gap: 1.2rem; flex-wrap: wrap; padding-top: 0.5rem; }
  .ct-direct p { color: var(--text-mute); }
  .ct-badges { display: flex; flex-wrap: wrap; gap: 0.5rem; }

  .ct-capture { display: flex; gap: 0.6rem; flex-wrap: wrap; }
  .ct-capture input {
    flex: 1; min-width: 220px;
    padding: 0.95rem 1.1rem;
    border-radius: 999px;
    border: 1px solid var(--line-strong);
    background: rgba(255,255,255,0.6);
    color: var(--text);
    font: inherit;
  }
  .ct-capture input:focus { outline: none; border-color: var(--violet); background: #fff; }

  /* Find us + map */
  .ct-map-grid { display: grid; grid-template-columns: 0.9fr 1.1fr; gap: clamp(2rem, 1rem + 4vw, 4rem); align-items: center; }
  .ct-map-copy { display: grid; gap: 1.1rem; }
  .ct-details { display: grid; gap: 0.9rem; margin-top: 0.4rem; }
  .ct-details li { display: grid; grid-template-columns: 5.5rem 1fr; gap: 0.8rem; align-items: baseline; font-size: 0.98rem; color: var(--text-dim); }
  .ct-d-k { font-size: 0.72rem; letter-spacing: 0.18em; text-transform: uppercase; color: var(--text-mute); font-weight: 600; }
  .ct-details a { color: var(--text); }
  .ct-details a:hover { color: var(--magenta); }
  .ct-map { border-radius: 24px; overflow: hidden; padding: 1px; background: var(--grad-soft); box-shadow: 0 30px 70px -30px rgba(123, 47, 247, 0.45); }
  .ct-map iframe { display: block; width: 100%; height: clamp(320px, 42vh, 460px); border: 0; border-radius: 23px; filter: saturate(1.05); }
  @media (max-width: 880px) { .ct-map-grid { grid-template-columns: 1fr; } }

  .ct-form-frame {
    border-radius: 24px;
    padding: 1px;
    background: var(--grad-soft);
    box-shadow: 0 30px 70px -30px rgba(220, 30, 227, 0.5);
  }
  .ct-form-frame iframe { border-radius: 23px; display: block; background: var(--surface); }
  .ct-secure { text-align: center; color: var(--text-mute); font-size: 0.85rem; margin-top: 1rem; }

  @media (max-width: 880px) {
    .ct-grid { grid-template-columns: 1fr; }
    .ct-copy { position: static; }
  }
</style>

<script>
  // Auto-size the quote iframe to its content.
  window.addEventListener('message', (e) => {
    if (e?.data?.type === 'qf-height' && typeof e.data.height === 'number') {
      const frame = document.getElementById('quote-iframe') as HTMLIFrameElement | null;
      if (frame) frame.style.height = Math.max(600, e.data.height + 24) + 'px';
    }
  });

  // Quick email capture -> opens the visitor's mail client, pre-addressed to us.
  const capture = document.querySelector('[data-capture]') as HTMLFormElement | null;
  capture?.addEventListener('submit', (e) => {
    e.preventDefault();
    const input = capture.querySelector('input[type=email]') as HTMLInputElement | null;
    const email = input?.value?.trim();
    if (!email) return;
    const subject = encodeURIComponent('New inquiry from the REmixed website');
    const body = encodeURIComponent(`Hi REmixed team,\n\nI'd love to hear from you about my event.\nYou can reach me at: ${email}\n\nThanks!`);
    window.location.href = `mailto:info@remixedeventsllc.com?subject=${subject}&body=${body}`;
  });
</script>
