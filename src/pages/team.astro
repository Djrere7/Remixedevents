---
import Base from '../layouts/Base.astro';
import PageHeader from '../components/PageHeader.astro';
import Media from '../components/Media.astro';
import Marquee from '../components/Marquee.astro';
import { awards, stats, site } from '../data/site';

const team = [
  {
    name: 'DJ ReRe',
    role: 'Founder, DJ, and Creative Director',
    img: '/img/team-rere.jpg',
    alt: 'Miami female DJ and founder of REmixed Events, DJ ReRe',
    bio: 'The rare find who started it all. DJ ReRe is known for reading the room, leading with confidence, and creating celebrations that feel stylish, smooth, and full of life. She sets the standard for the REmixed Events sound, service, and energy.',
    link: 'https://www.djrere.com',
  },
  {
    name: 'DJ Pynk Honey',
    role: 'DJ, Creative Media Director, and Content Creator',
    img: '/img/team-pynk.jpg',
    alt: 'Miami female DJ and content creator DJ Pynk Honey of REmixed Events',
    bio: 'A DJ with main-character energy and a creative eye. Pynk Honey brings music, visuals, and storytelling together with serious presence behind the booth and behind the camera.',
  },
  {
    name: 'DJ Ibe',
    role: 'DJ, Host, Breakdancer, and Hype Lead',
    img: '/img/team-ibe.jpg',
    alt: 'Miami female DJ, host, and breakdancer DJ Ibe of REmixed Events',
    bio: 'DJ Ibe brings charisma, movement, and mic confidence to every event. As a breakdancer, performer, and versatile open-format DJ, she knows how to read the room, keep the crowd engaged, and bring the energy when it matters most. She is professional, fun, timeline-aware, and always ready to rock your event.',
  },
];

// The team together + at real events — so visitors know who they're booking.
const teamShots = [
  { src: '/img/team-fun.jpg', alt: 'The REmixed Events team in branded tees', aspect: '3/4' },
  { src: '/img/prom-hype.jpg', alt: 'DJ IB hyping the crowd on the mic at a school dance', aspect: '3/2' },
  { src: '/img/prom-dj-ib.jpg', alt: 'DJ IB on the decks at a school dance', aspect: '3/2' },
  { src: '/img/team-pynk.jpg', alt: 'DJ Pynk Honey of REmixed Events', aspect: '3/4' },
  { src: '/img/rere-decks.jpg', alt: 'DJ ReRe behind the booth', aspect: '3/4' },
  { src: '/img/prom-breakdance.jpg', alt: 'A REmixed Events dance floor opening up at a school dance', aspect: '3/2' },
  { src: '/img/booth-setup.jpg', alt: 'A REmixed Events DJ booth setup, behind the scenes', aspect: '3/2' },
  { src: '/img/prom-crowd.jpg', alt: 'A full prom crowd at a REmixed Events event in South Florida', aspect: '3/2' },
  { src: '/img/dj-outdoor.jpg', alt: 'A REmixed Events female DJ at an outdoor event', aspect: '3/4' },
];
---

<Base
  fullTitle="Meet the Female DJs Behind REmixed Events | Miami DJ Team"
  description="Meet the female DJs, hosts, creators, and event pros behind REmixed Events, South Florida’s female DJ entertainment company."
>
  <PageHeader
    kicker="The collective"
    title="Meet the women behind"
    emphasis="REmixed Events."
    emphasisClass="font-stroke"
    lede="REmixed Events is powered by female DJs, hosts, creators, and event pros who bring style, skill, and unforgettable energy to every room. Different styles. Same standard. Good music. Pretty setups. Smooth energy. No awkward moments."
  />

  <!-- ROSTER -->
  <section class="roster-section">
    <div class="container wide roster">
      {team.map((m, i) => (
        <article class="member" data-reveal style={`--reveal-delay:${i * 90}ms`}>
          {m.link ? (
            <a href={m.link} target="_blank" rel="noopener" class="member-photo-link" aria-label={`Visit ${m.name}'s website`}>
              <Media src={m.img} alt={m.alt} aspect="4/5" position="center top" feather={false} class="member-photo" />
            </a>
          ) : (
            <Media src={m.img} alt={m.alt} aspect="4/5" position="center top" feather={false} class="member-photo" />
          )}
          <div class="member-body">
            <h2 class="member-name">
              {m.link ? <a href={m.link} target="_blank" rel="noopener" class="member-name-link">{m.name}</a> : m.name}
            </h2>
            <p class="member-role gtext">{m.role}</p>
            <p class="member-bio">{m.bio}</p>
            {m.link && <a href={m.link} target="_blank" rel="noopener" class="member-link">Visit djrere.com <span class="arrow">→</span></a>}
          </div>
        </article>
      ))}
    </div>
  </section>

  <!-- TEAM IN ACTION -->
  <section class="section tight">
    <div class="container wide">
      <div class="team-gallery-head">
        <p class="kicker" data-reveal style="display:flex;justify-content:center">Together in the room</p>
        <h2 class="h2" data-reveal style="--reveal-delay:80ms">Meet the women behind <span class="font-stroke gtext">REmixed Events.</span></h2>
        <p class="lede mx-auto" data-reveal style="--reveal-delay:140ms">Different styles, same standard. This is the team you’re actually booking, at real events across South Florida.</p>
      </div>
      <div class="team-gallery">
        {teamShots.map((g, i) => (
          <figure class="tg-item" data-reveal style={`--reveal-delay:${i * 60}ms`}>
            <Media src={g.src} alt={g.alt} aspect={g.aspect} feather={false} />
          </figure>
        ))}
      </div>
    </div>
  </section>

  <!-- GROUP PHOTO -->
  <section class="section tight">
    <div class="container wide group-wrap">
      <Media src="/img/team.jpg" alt="The female DJ team behind REmixed Events at a South Florida event" aspect="2/3" feather={false} position="center 20%" class="group-photo" />
      <div class="group-cap-block">
        <p class="group-cap serif">We’ve got your back.</p>
        <p class="group-cap-copy">From setup to last song, our team brings white glove support, calm communication, and the kind of energy that keeps everything flowing.</p>
      </div>
    </div>
  </section>

  <!-- STATS -->
  <section class="section tight">
    <div class="container wide">
      <div class="about-stats">
        {stats.map((s, i) => (
          <div class="astat" data-reveal style={`--reveal-delay:${i * 80}ms`}>
            <span class="astat-v gtext">{s.value}</span>
            <span class="astat-l">{s.label}</span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- MIXHER -->
  <section class="section">
    <div class="container wide">
      <div class="mixher card on-grad" data-reveal>
        <div class="mixher-glow glow" aria-hidden="true"></div>
        <div class="mixher-inner">
          <p class="kicker">Giving back</p>
          <h2 class="h1"><span class="gtext">MixHer,</span> <span class="font-stroke">handing women the mic.</span></h2>
          <p class="lede">
            Through her nonprofit MixHer, DJ ReRe mentors and platforms emerging female DJs and artists,
            helping them assert their voice and take the main stage. Every REmixed event is a working
            extension of that mission.
          </p>
          <a href={site.mixherUrl} target="_blank" rel="noopener" class="btn btn-primary btn-lg">Visit MixHer <span class="arrow">→</span></a>
        </div>
      </div>
    </div>
  </section>

  <section class="section tight awards-band">
    <Marquee items={awards} speed={30} />
  </section>
</Base>

<style>
  .roster { display: grid; gap: clamp(2rem, 1.4rem + 3vw, 4rem); }
  .member {
    display: grid;
    grid-template-columns: 0.9fr 1.1fr;
    gap: clamp(1.5rem, 1rem + 3vw, 3.5rem);
    align-items: center;
  }
  .member:nth-child(even) { grid-template-columns: 1.1fr 0.9fr; }
  .member:nth-child(even) .member-photo { order: 2; }
  .member-body { display: grid; gap: 0.7rem; align-content: center; }
  .member-name { font-family: var(--font-display); font-size: clamp(2rem, 1.4rem + 2.4vw, 3.2rem); font-weight: 600; letter-spacing: -0.02em; }
  .member-name-link { color: inherit; text-decoration: none; background-image: linear-gradient(var(--violet), var(--violet)); background-size: 0% 2px; background-repeat: no-repeat; background-position: left 92%; transition: background-size 0.3s var(--ease); }
  .member-name-link:hover { background-size: 100% 2px; }
  .member-photo-link { display: block; transition: transform 0.4s var(--ease); }
  .member-photo-link:hover { transform: translateY(-4px); }
  .member-link { display: inline-flex; align-items: center; gap: 0.4rem; margin-top: 0.6rem; font-weight: 600; font-size: 0.98rem; color: var(--violet); width: fit-content; }
  .member-link:hover { color: var(--magenta); }
  .member-role { font-family: var(--font-sans); font-weight: 600; font-size: 0.82rem; letter-spacing: 0.16em; text-transform: uppercase; }
  .member-bio { color: var(--text-dim); font-size: clamp(1rem, 0.95rem + 0.3vw, 1.15rem); max-width: 52ch; }
  .member-photo { max-width: 460px; }
  .member:nth-child(even) .member-photo { justify-self: end; }

  @media (max-width: 760px) {
    .member, .member:nth-child(even) { grid-template-columns: 1fr; gap: 1.4rem; }
    .member:nth-child(even) .member-photo { order: 0; }
    .member-photo { max-width: 360px; }
  }

  .team-gallery-head { text-align: center; display: grid; gap: 0.9rem; justify-items: center; max-width: 46ch; margin: 0 auto clamp(1.8rem, 1.2rem + 2vw, 2.6rem); }
  .team-gallery { columns: 3 240px; column-gap: 1rem; }
  .tg-item { margin: 0 0 1rem; break-inside: avoid; border-radius: calc(var(--radius) + 4px); overflow: hidden; box-shadow: 0 22px 48px -30px rgba(40, 16, 80, 0.4); }
  @media (max-width: 560px) { .team-gallery { columns: 2 150px; } }

  .roster-section { padding-block: clamp(1.5rem, 1rem + 2vw, 2.75rem) clamp(3rem, 2rem + 4vw, 5rem); }
  .group-wrap { display: grid; gap: 1rem; justify-items: center; }
  .group-wrap :global(.group-photo) { max-width: 440px; }
  .group-cap-block { display: grid; gap: 0.6rem; justify-items: center; text-align: center; max-width: 48ch; }
  .group-cap { font-size: clamp(1.4rem, 1.1rem + 1.4vw, 2.1rem); color: var(--text); text-align: center; }
  .group-cap-copy { color: var(--text-dim); font-size: 1rem; }

  .about-stats { display: grid; grid-template-columns: repeat(4, 1fr); gap: 1rem; border-block: 1px solid var(--line); padding-block: clamp(1.8rem, 1.2rem + 2vw, 2.6rem); }
  .astat { display: grid; gap: 0.3rem; text-align: center; }
  .astat-v { font-family: var(--font-display); font-weight: 700; font-size: clamp(2.2rem, 1.6rem + 2.4vw, 3.4rem); letter-spacing: -0.03em; line-height: 1; }
  .astat-l { color: var(--text-dim); font-size: 0.9rem; }
  @media (max-width: 620px) { .about-stats { grid-template-columns: 1fr 1fr; gap: 1.6rem; } }

  .mixher { padding: clamp(2.2rem, 1.5rem + 4vw, 4.5rem); border: 0; overflow: hidden; box-shadow: 0 40px 80px -36px rgba(123, 47, 247, 0.55); }
  .mixher-glow { width: 55%; height: 130%; top: -15%; right: -8%; background: radial-gradient(circle, rgba(255,255,255,0.4), transparent 65%); opacity: 0.55; filter: blur(60px); }
  .mixher-inner { position: relative; z-index: 1; display: grid; gap: 1.3rem; max-width: 640px; }
  .mixher-inner .h1 { max-width: 18ch; }
  .awards-band { border-top: 1px solid var(--line); }
</style>
