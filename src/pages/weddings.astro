---
import Base from '../layouts/Base.astro';
import PageHeader from '../components/PageHeader.astro';
import TestimonialCard from '../components/TestimonialCard.astro';
import Media from '../components/Media.astro';
import { testimonials, site } from '../data/site';

const wedGallery = [
  { src: '/img/venue-uplights.jpg', alt: 'Ballroom transformed with custom uplighting and a monogram floor', aspect: '4/5' },
  { src: '/img/production-sparks.jpg', alt: 'Cold spark fountains for a grand entrance', aspect: '4/3' },
  { src: '/img/booth-setup.jpg', alt: 'Elegant DJ booth with warm uplighting', aspect: '4/3' },
  { src: '/img/led-pool.jpg', alt: 'LED accents glowing across a waterfront reception', aspect: '4/5' },
];

const includes = [
  { t: 'Ceremony', d: 'A string trio or curated playlist, a perfectly timed processional, and crystal clear sound for your vows.' },
  { t: 'Cocktail hour', d: 'Live musician add ons and open format sets that set the mood while guests mingle.' },
  { t: 'Reception', d: 'Grand entrance to last dance, read in real time so the floor never empties.' },
  { t: 'The details', d: 'Custom mixes & remixes, bilingual MC and hosting, and a planning process that takes the stress off you.' },
];

const wedTestimonials = testimonials.filter((t) => t.date === 'Wedding').concat(testimonials.filter((t) => t.date !== 'Wedding')).slice(0, 2);
---

<Base title="Luxury Weddings" description="Award winning wedding entertainment in South Florida. REmixed Events and DJ ReRe craft ceremonies and receptions that keep the dance floor full, named Best Female Wedding DJ Provider.">
  <PageHeader
    kicker="Award winning wedding entertainment"
    title="A reception they’ll"
    emphasis="never forget."
    emphasisClass="font-stroke"
    lede="Named Best Female Wedding DJ Provider at the Global Wedding Awards, REmixed brings ceremony to last dance artistry, custom remixes and a read the room instinct that keeps every generation on the floor."
  >
    <div class="ph-actions" data-reveal style="--reveal-delay:200ms">
      <a href="/contact" class="btn btn-primary btn-lg">Check your date <span class="arrow">→</span></a>
      <a href={`mailto:${site.email}`} class="btn btn-ghost btn-lg">Ask a question</a>
    </div>
  </PageHeader>

  <!-- AWARD BANNER -->
  <section class="section tight">
    <div class="container wide">
      <div class="award-banner card" data-reveal>
        <span class="award-icon gtext" aria-hidden="true">♛</span>
        <div>
          <p class="award-title">Best Female Wedding DJ Provider</p>
          <p class="award-sub">Global Wedding Awards · Editor’s Choice, WeddingRule · DJane Top 100</p>
        </div>
      </div>
    </div>
  </section>

  <!-- WHAT'S INCLUDED -->
  <section class="section">
    <div class="container wide">
      <div class="sec-head">
        <div>
          <p class="kicker" data-reveal>From “I do” to last call</p>
          <h2 class="h2" data-reveal style="--reveal-delay:80ms">Every moment, beautifully scored.</h2>
        </div>
      </div>
      <div class="inc-grid">
        {includes.map((c, i) => (
          <article class="card card-glow inc" data-reveal style={`--reveal-delay:${i * 70}ms`}>
            <span class="inc-n gtext">{String(i + 1).padStart(2, '0')}</span>
            <h3 class="h3">{c.t}</h3>
            <p>{c.d}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- GALLERY -->
  <section class="section tight">
    <div class="container wide">
      <div class="sec-head">
        <div>
          <p class="kicker" data-reveal>Real celebrations</p>
          <h2 class="h2" data-reveal style="--reveal-delay:80ms">A night styled down to the <span class="font-stroke gtext">last dance.</span></h2>
        </div>
      </div>
      <div class="wed-gallery">
        {wedGallery.map((g) => (
          <Media src={g.src} alt={g.alt} aspect={g.aspect} />
        ))}
      </div>
    </div>
  </section>

  <!-- TESTIMONIALS -->
  <section class="section section-light">
    <div class="container wide">
      <div class="sec-head">
        <div>
          <p class="kicker" data-reveal>Happily ever afters</p>
          <h2 class="h2" data-reveal style="--reveal-delay:80ms">Loved by couples across South Florida.</h2>
        </div>
      </div>
      <div class="wed-quotes">
        {wedTestimonials.map((t, i) => <TestimonialCard {...t} delay={i * 80} />)}
      </div>
    </div>
  </section>
</Base>

<style>
  .ph-actions { display: flex; gap: 0.8rem; flex-wrap: wrap; margin-top: 2rem; }

  .award-banner {
    display: flex; align-items: center; gap: 1.4rem;
    padding: clamp(1.4rem, 1rem + 1.5vw, 2.2rem);
    background: linear-gradient(120deg, var(--surface-2), var(--ink-2));
    border-color: var(--line-strong);
  }
  .award-icon { font-size: 2.6rem; line-height: 1; }
  .award-title { font-family: var(--font-display); font-size: clamp(1.2rem, 1rem + 1vw, 1.7rem); font-weight: 600; letter-spacing: -0.01em; }
  .award-sub { color: var(--text-dim); font-size: 0.92rem; margin-top: 0.3rem; }

  .sec-head { margin-bottom: clamp(2rem, 1.5rem + 2vw, 3rem); }
  .sec-head > div { display: grid; gap: 0.9rem; }

  .inc-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 1.1rem; }
  .inc { padding: 1.8rem 1.5rem; display: grid; gap: 0.7rem; align-content: start; }
  .inc-n { font-family: var(--font-display); font-weight: 700; font-size: 1.6rem; letter-spacing: -0.02em; }
  .inc p { color: var(--text-dim); font-size: 0.94rem; }
  @media (max-width: 860px) { .inc-grid { grid-template-columns: 1fr 1fr; } }
  @media (max-width: 480px) { .inc-grid { grid-template-columns: 1fr; } }

  .wed-quotes { display: grid; grid-template-columns: 1fr 1fr; gap: 1.2rem; }
  @media (max-width: 760px) { .wed-quotes { grid-template-columns: 1fr; max-width: 560px; } }

  .wed-gallery { display: grid; grid-template-columns: repeat(4, 1fr); gap: 1.1rem; align-items: start; }
  @media (max-width: 820px) { .wed-gallery { grid-template-columns: 1fr 1fr; } }
</style>
