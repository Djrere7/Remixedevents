---
import Base from '../layouts/Base.astro';
import Marquee from '../components/Marquee.astro';
import ServiceCard from '../components/ServiceCard.astro';
import TestimonialCard from '../components/TestimonialCard.astro';
import Media from '../components/Media.astro';
import YouTubeEmbed from '../components/YouTubeEmbed.astro';
import Faq from '../components/Faq.astro';
import { services, testimonials, awards, stats, site, eventTypes } from '../data/site';

const faqs = [
  { q: 'Do you offer female DJs in Miami?', a: 'Yes. REmixed Events specializes in female DJ entertainment for weddings, brand events, influencer events, yacht parties, private celebrations, and special events across Miami and South Florida.' },
  { q: 'What makes REmixed Events different from other DJ companies?', a: 'REmixed Events is a female-led DJ entertainment company known for stylish DJs, polished production, warm communication, and events that feel personal instead of cookie-cutter.' },
  { q: 'Do you only serve Miami?', a: 'REmixed Events is based in Miami Beach and serves Miami, South Florida, destination events, and celebrations beyond.' },
];

const gallery = [
  { src: '/img/wed-clouds.jpg', label: 'Miami Wedding Energy', caption: 'Female wedding DJs, full dance floors, and moments that feel like the couple.', alt: 'Cold sparks and dancing on clouds for a Miami wedding by REmixed Events', aspect: '4/3' },
  { src: '/img/brand-fenty.jpg', label: 'Brand Event Energy', caption: 'Female DJ entertainment for brands that want the room to feel intentional and camera ready.', alt: 'REmixed Events female DJ at a Savage X Fenty brand event in Miami', aspect: '4/5' },
  { src: '/img/cold-sparks.jpg', label: 'Cold Spark Moments', caption: 'Grand entrances and first dances lit up by cold sparks.', alt: 'Cold sparks for a Miami wedding by REmixed Events', aspect: '4/3' },
  { src: '/img/wed-reception.jpg', label: 'Dance Floor Moments', caption: 'The part of the night everyone keeps talking about.', alt: 'A packed Miami wedding reception dance floor by REmixed Events', aspect: '4/5' },
  { src: '/img/photobooth.jpg', label: 'Pretty Little Details', caption: 'Photo booths, lighting, and production that make the room feel complete.', alt: 'REmixed Events photo booth setup for a Miami wedding', aspect: '4/3' },
  { src: '/img/venue-uplights.jpg', label: 'Lit Just Right', caption: 'Custom uplighting that transforms any venue.', alt: 'Custom uplighting at a South Florida wedding by REmixed Events', aspect: '4/5' },
];
---

<Base
  fullTitle="Miami Female DJs & Event Entertainment | REmixed Events"
  description="REmixed Events is South Florida’s female DJ entertainment company for luxe weddings, brand and influencer events, yacht parties, and special events in Miami."
>
  <!-- ============ HERO ============ -->
  <section class="hero">
    <div class="hero-media" aria-hidden="true">
      <video class="hero-video" autoplay muted loop playsinline preload="metadata" poster="/video/hero-poster.jpg">
        <source src="/video/hero.mp4" type="video/mp4" />
      </video>
      <div class="hero-scrim"></div>
    </div>

    <div class="container wide hero-inner">
      <p class="kicker hero-kicker" data-reveal>South Florida’s Female DJ Entertainment Company</p>

      <h1 class="display hero-title">
        <span class="line" data-reveal style="--reveal-delay:60ms">Not Your Ordinary</span>
        <span class="line hero-accent font-stroke" data-reveal style="--reveal-delay:180ms">DJ Company</span>
      </h1>

      <div class="hero-foot">
        <p class="lede hero-lede" data-reveal style="--reveal-delay:300ms">
          REmixed Events brings stylish female DJs, polished production and unforgettable energy to luxe weddings,
          brand and influencer events, yacht parties and special events across Miami, South Florida and beyond.
        </p>
        <div class="hero-actions" data-reveal style="--reveal-delay:360ms">
          <a href={site.calendly} target="_blank" rel="noopener" class="btn btn-primary btn-lg">Schedule a Free Consultation <span class="arrow">→</span></a>
          <a href="/experiences" class="btn btn-ghost btn-lg">Explore Experiences</a>
        </div>
      </div>
    </div>

    <a href="#intro" class="hero-scroll" aria-label="Scroll to content">
      <span class="hero-scroll-dot"></span>
    </a>
  </section>

  <!-- ============ AWARDS MARQUEE ============ -->
  <section class="section tight awards-strip">
    <div class="container wide">
      <p class="awards-label">Recognized & trusted</p>
    </div>
    <Marquee items={awards} />
  </section>

  <!-- ============ INTRO + STATS ============ -->
  <section class="section" id="intro">
    <div class="container wide intro-grid">
      <div class="intro-copy">
        <p class="kicker" data-reveal>The REmixed Events difference</p>
        <h2 class="h1" data-reveal style="--reveal-delay:80ms">
          What once felt like a <span class="font-stroke gtext">rare find</span> is now a complete female DJ company.
        </h2>
        <p class="lede" data-reveal style="--reveal-delay:140ms">
          For years, DJ ReRe was the Miami female DJ people were always hoping to find. Professional. Stylish. Easy
          to work with. Completely in tune with the room. That became the heartbeat of REmixed Events, a female led
          DJ entertainment company built for people who care about the music, the look, the flow and the feeling of the entire event.
        </p>
        <div class="intro-cta" data-reveal style="--reveal-delay:200ms">
          <a href="/team" class="tlink">Meet the women behind REmixed Events <span class="arrow">→</span></a>
        </div>
      </div>

      <div class="stats">
        {stats.map((s, i) => (
          <div class="stat card" data-reveal style={`--reveal-delay:${i * 90}ms`}>
            <span class="stat-value gtext">{s.value}</span>
            <span class="stat-label">{s.label}</span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ============ SERVICES ============ -->
  <section class="section services">
    <div class="container wide">
      <div class="sec-head">
        <div>
          <p class="kicker" data-reveal>Who we are</p>
          <h2 class="h2" data-reveal style="--reveal-delay:80ms">Meet the women behind <span class="font-stroke gtext">REmixed Events.</span></h2>
          <p class="lede" data-reveal style="--reveal-delay:140ms">
            We are a female led team of DJs, hosts, creators and event pros who know how to bring the room to life.
            Whether you are booking a Miami female DJ for a wedding, brand event, influencer event, yacht party or
            private celebration, our team brings style, skill and real crowd reading energy.
          </p>
        </div>
        <a href="/experiences" class="tlink sec-head-link" data-reveal>Explore female DJ entertainment in Miami <span class="arrow">→</span></a>
      </div>

      <div class="svc-grid">
        {services.map((s, i) => <ServiceCard {...s} delay={i * 70} />)}
      </div>
    </div>
  </section>

  <!-- ============ SHOWREEL ============ -->
  <section class="section reel">
    <div class="container wide">
      <div class="reel-head">
        <p class="kicker" data-reveal>Press play</p>
        <h2 class="h2" data-reveal style="--reveal-delay:80ms">See the <span class="font-stroke gtext">energy</span> in motion.</h2>
        <p class="lede mx-auto" data-reveal style="--reveal-delay:140ms">From weddings and brand events to the celebrations in between, this is REmixed Events in the room.</p>
      </div>
      <YouTubeEmbed id="JbOwx8k0od4" title="REmixed Events showreel" class="reel-frame" />
    </div>
  </section>

  <!-- ============ EVENTS WE LOVE ============ -->
  <section class="section tight">
    <div class="container wide">
      <div class="center-head-x">
        <p class="kicker mx-auto" data-reveal style="display:flex;justify-content:center">Events we love</p>
        <h2 class="h2" data-reveal style="--reveal-delay:80ms">The rooms and moments we love <span class="font-stroke gtext">bringing to life.</span></h2>
        <p class="lede mx-auto" data-reveal style="--reveal-delay:140ms">A look at the rooms, brands, celebrations and moments we love bringing to life across Miami and South Florida.</p>
      </div>
      <div class="evt-chips" data-reveal style="--reveal-delay:180ms">
        {eventTypes.map((t) => <span class="chip evt-chip">{t}</span>)}
      </div>
    </div>
  </section>

  <!-- ============ GALLERY ============ -->
  <section class="section tight">
    <div class="container wide">
      <div class="sec-head">
        <div>
          <p class="kicker" data-reveal>The gallery</p>
          <h2 class="h2" data-reveal style="--reveal-delay:80ms">REmixed Events Moments.</h2>
          <p class="lede" data-reveal style="--reveal-delay:120ms">Real events. Real dance floors. Real moments brought to life by REmixed Events.</p>
        </div>
        <a href="/contact" class="tlink sec-head-link" data-reveal>Book a Miami female DJ <span class="arrow">→</span></a>
      </div>
      <div class="gallery">
        {gallery.map((g) => (
          <figure class="gallery-item gcap" data-reveal>
            <Media src={g.src} alt={g.alt} aspect={g.aspect} feather={false} />
            <figcaption class="gcap-label">
              <span class="gcap-k">{g.label}</span>
              {g.caption && <span class="gcap-c">{g.caption}</span>}
            </figcaption>
          </figure>
        ))}
      </div>
    </div>
  </section>

  <!-- ============ TESTIMONIALS ============ -->
  <section class="section">
    <div class="container wide">
      <div class="sec-head">
        <div>
          <p class="kicker" data-reveal>Straight from Google</p>
          <h2 class="h2" data-reveal style="--reveal-delay:80ms">Rated <span class="font-stroke gtext">5.0</span> by clients across South Florida.</h2>
        </div>
      </div>
      <div class="quote-grid">
        {testimonials.map((t, i) => <TestimonialCard {...t} delay={i * 80} />)}
      </div>
    </div>
  </section>

  <!-- ============ FAQ ============ -->
  <Faq items={faqs} kicker="Miami female DJ FAQ" heading="Your questions, answered." />
</Base>

<style>
  /* ---------- HERO (video) ---------- */
  .hero {
    position: relative;
    min-height: 100svh;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    padding-top: 120px;
    padding-bottom: clamp(2.5rem, 1.5rem + 4vw, 5rem);
    overflow: hidden;
    isolation: isolate;
  }
  .hero-media { position: absolute; inset: 0; z-index: 0; }
  .hero-video { width: 100%; height: 100%; object-fit: cover; object-position: center; }
  .hero-scrim {
    position: absolute; inset: 0;
    background:
      linear-gradient(180deg, rgba(8,4,15,0.42) 0%, rgba(8,4,15,0.10) 24%, rgba(8,4,15,0.18) 55%, rgba(8,4,15,0.84) 100%),
      linear-gradient(90deg, rgba(8,4,15,0.55) 0%, rgba(8,4,15,0.08) 58%, transparent 100%);
  }
  .hero-inner { position: relative; z-index: 2; }
  .hero-kicker { margin-bottom: 1.6rem; color: #fff; }
  .hero-title { margin-bottom: clamp(1.6rem, 1rem + 3vw, 2.8rem); color: #fff; text-shadow: 0 2px 30px rgba(0,0,0,0.35); }
  .hero-title .line { display: block; }
  .hero-accent {
    background: linear-gradient(110deg, #ffffff 0%, #ffd8f6 45%, #cdb6ff 100%);
    -webkit-background-clip: text; background-clip: text; -webkit-text-fill-color: transparent;
  }
  .hero-lede { color: rgba(255,255,255,0.9); }
  .hero-lede strong { color: #fff; font-weight: 600; }
  .hero-actions { display: flex; gap: 0.8rem; flex-wrap: wrap; justify-self: start; }
  .hero-foot {
    display: grid;
    grid-template-columns: 1.1fr 0.9fr;
    gap: 2.5rem;
    align-items: end;
  }

  .hero-scroll {
    position: absolute;
    bottom: 1.4rem; left: 50%;
    transform: translateX(-50%);
    width: 26px; height: 42px;
    border: 1.5px solid rgba(255,255,255,0.5);
    border-radius: 14px;
    display: flex;
    justify-content: center;
    padding-top: 7px;
    z-index: 2;
  }
  .hero-scroll-dot {
    width: 4px; height: 8px; border-radius: 4px;
    background: #fff;
    animation: scrolldot 1.8s var(--ease) infinite;
  }
  @keyframes scrolldot { 0% { opacity: 0; transform: translateY(-4px); } 40% { opacity: 1; } 80%, 100% { opacity: 0; transform: translateY(8px); } }

  @media (max-width: 820px) {
    .hero-foot { grid-template-columns: 1fr; gap: 1.8rem; align-items: start; }
    .hero-scroll { display: none; }
  }

  /* ---------- AWARDS ---------- */
  .awards-strip { padding-block: clamp(2rem, 1.5rem + 2vw, 3rem); border-block: 1px solid var(--line); }
  .awards-label {
    text-align: center;
    font-size: 0.74rem;
    letter-spacing: 0.24em;
    text-transform: uppercase;
    color: var(--text-mute);
    margin-bottom: 1.6rem;
  }

  /* ---------- INTRO + STATS ---------- */
  .intro-grid {
    display: grid;
    grid-template-columns: 1.1fr 0.9fr;
    gap: clamp(2.5rem, 1rem + 5vw, 5rem);
    align-items: center;
  }
  .intro-copy { display: grid; gap: 1.4rem; }
  .stats {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
  }
  .stat {
    padding: clamp(1.4rem, 1rem + 1.5vw, 2.2rem);
    display: grid;
    gap: 0.4rem;
    align-content: center;
  }
  .stat-value {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: clamp(2.4rem, 1.8rem + 2.5vw, 3.6rem);
    line-height: 1;
    letter-spacing: -0.03em;
  }
  .stat-label { color: var(--text-dim); font-size: 0.92rem; }

  @media (max-width: 820px) {
    .intro-grid { grid-template-columns: 1fr; }
  }

  /* ---------- SECTION HEADINGS ---------- */
  .sec-head {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: 1.5rem;
    margin-bottom: clamp(2rem, 1.5rem + 2vw, 3.2rem);
  }
  .sec-head > div { display: grid; gap: 0.9rem; }
  .sec-head-link { padding-bottom: 0.5rem; }

  /* ---------- SERVICES GRID ---------- */
  .svc-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1.2rem;
  }
  @media (max-width: 640px) { .svc-grid { grid-template-columns: 1fr; } .sec-head { flex-direction: column; align-items: flex-start; } }
  .svc { text-decoration: none; color: inherit; }

  /* ---------- CORPORATE BAND ---------- */
  .corp-card {
    padding: clamp(2.2rem, 1.5rem + 4vw, 4.5rem);
    background: var(--grad);
    border: 0;
    overflow: hidden;
    box-shadow: 0 40px 80px -36px rgba(123, 47, 247, 0.55);
  }
  .corp-glow {
    width: 60%; height: 130%;
    top: -15%; right: -12%;
    background: radial-gradient(circle, rgba(255,255,255,0.4), transparent 65%);
    opacity: 0.55;
    filter: blur(60px);
  }
  .corp-inner { position: relative; z-index: 1; max-width: 720px; }
  .corp-copy { display: grid; gap: 1.4rem; }
  .corp-list { display: grid; gap: 0.7rem; margin: 0.3rem 0; }
  .corp-list li {
    display: flex;
    gap: 0.7rem;
    color: rgba(255, 255, 255, 0.92);
    font-size: 1rem;
  }
  .corp-list li::before {
    content: "✦";
    color: #fff;
    flex-shrink: 0;
  }

  /* ---------- SHOWREEL ---------- */
  .reel-head { text-align: center; display: grid; gap: 0.9rem; justify-items: center; max-width: 60ch; margin: 0 auto clamp(2rem, 1.5rem + 2vw, 3rem); }
  .reel :global(.reel-frame) { box-shadow: 0 50px 90px -50px rgba(123, 47, 247, 0.6); }

  /* ---------- EVENTS WE LOVE ---------- */
  .center-head-x { text-align: center; display: grid; gap: 0.9rem; justify-items: center; max-width: 44ch; margin: 0 auto clamp(2rem, 1.5rem + 2vw, 3rem); }
  .evt-chips { display: flex; flex-wrap: wrap; gap: 0.6rem; justify-content: center; max-width: 940px; margin: 0 auto; }
  .evt-chip { font-size: 0.92rem; padding: 0.6em 1.1em; }

  /* ---------- GALLERY (masonry) ---------- */
  .gallery { columns: 3 240px; column-gap: 1.1rem; }
  .gallery-item {
    margin: 0 0 1.1rem;
    break-inside: avoid;
    position: relative;
    border-radius: calc(var(--radius) + 4px);
    overflow: hidden;
    box-shadow: 0 22px 48px -30px rgba(40, 16, 80, 0.4);
  }
  .gcap-label {
    position: absolute;
    left: 0; right: 0; bottom: 0;
    z-index: 2;
    display: grid;
    gap: 0.3rem;
    padding: 2.6rem 1.15rem 1.1rem;
    background: linear-gradient(to top, rgba(8, 4, 15, 0.85), rgba(8, 4, 15, 0.25) 55%, transparent);
    pointer-events: none;
  }
  .gcap-k { font-size: 0.68rem; font-weight: 700; letter-spacing: 0.18em; text-transform: uppercase; color: #fff; }
  .gcap-c { font-family: var(--font-serif); font-style: italic; font-size: 0.95rem; line-height: 1.35; color: rgba(255,255,255,0.92); }
  @media (max-width: 560px) { .gallery { columns: 2 150px; } }

  /* ---------- TESTIMONIALS GRID ---------- */
  .quote-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.2rem;
  }
  @media (max-width: 900px) { .quote-grid { grid-template-columns: 1fr; max-width: 560px; } }
</style>
