---
import Base from '../layouts/Base.astro';
import Marquee from '../components/Marquee.astro';
import ServiceCard from '../components/ServiceCard.astro';
import TestimonialCard from '../components/TestimonialCard.astro';
import Media from '../components/Media.astro';
import { services, testimonials, awards, stats, site } from '../data/site';

const gallery = [
  { src: '/img/rere-decks.jpg', alt: 'DJ ReRe on the decks in a REmixed Events tee', aspect: '4/5' },
  { src: '/img/dj-outdoor.jpg', alt: 'DJ ReRe bringing the energy at an outdoor activation', aspect: '4/3' },
  { src: '/img/venue-uplights.jpg', alt: 'Uplit ballroom with a monogram dance floor', aspect: '4/3' },
  { src: '/img/production-sparks.jpg', alt: 'Cold spark fountains lighting up a grand entrance', aspect: '4/5' },
  { src: '/img/rere-disco.jpg', alt: 'DJ ReRe with a disco ball', aspect: '4/3' },
  { src: '/img/corporate-acc.jpg', alt: 'Branded booth at a corporate activation', aspect: '4/5' },
];
---

<Base>
  <!-- ============ HERO ============ -->
  <section class="hero">
    <div class="hero-media" aria-hidden="true">
      <video class="hero-video" autoplay muted loop playsinline preload="metadata" poster="/video/hero-poster.jpg">
        <source src="/video/hero.mp4" type="video/mp4" />
      </video>
      <div class="hero-scrim"></div>
    </div>

    <div class="container wide hero-inner">
      <p class="kicker hero-kicker" data-reveal>South Florida’s Premier Events Company</p>

      <h1 class="display hero-title">
        <span class="line" data-reveal style="--reveal-delay:60ms">We don’t just play music.</span>
        <span class="line hero-accent font-stroke" data-reveal style="--reveal-delay:180ms">We move people.</span>
      </h1>

      <div class="hero-foot">
        <p class="lede hero-lede" data-reveal style="--reveal-delay:300ms">
          Luxe, high energy entertainment for brand activations, VIP soirées, women led experiences,
          chic weddings and corporate takeovers. An all female collective led by award winning <strong>DJ ReRe</strong>.
        </p>
        <div class="hero-actions" data-reveal style="--reveal-delay:360ms">
          <a href="/contact" class="btn btn-primary btn-lg">Request a Quote <span class="arrow">→</span></a>
          <a href="/experiences" class="btn btn-ghost btn-lg">See what we do</a>
        </div>
      </div>
    </div>

    <a href="#intro" class="hero-scroll" aria-label="Scroll to content">
      <span class="hero-scroll-dot"></span>
    </a>
  </section>

  <!-- ============ AWARDS MARQUEE ============ -->
  <section class="section tight awards-strip">
    <div class="container wide">
      <p class="awards-label">Recognized & trusted</p>
    </div>
    <Marquee items={awards} />
  </section>

  <!-- ============ INTRO + STATS ============ -->
  <section class="section" id="intro">
    <div class="container wide intro-grid">
      <div class="intro-copy">
        <p class="kicker" data-reveal>The REmixed difference</p>
        <h2 class="h1" data-reveal style="--reveal-delay:80ms">
          Every event is a <span class="font-stroke gtext">production</span>, not a playlist.
        </h2>
        <p class="lede" data-reveal style="--reveal-delay:140ms">
          From the first beat to the last dance, we engineer atmosphere. Curated soundscapes, intelligent
          lighting and a read the room instinct you can’t fake. The result is the kind of night people
          can’t stop talking about.
        </p>
        <div class="intro-cta" data-reveal style="--reveal-delay:200ms">
          <a href="/about" class="tlink">Meet DJ ReRe & the collective <span class="arrow">→</span></a>
        </div>
      </div>

      <div class="stats">
        {stats.map((s, i) => (
          <div class="stat card" data-reveal style={`--reveal-delay:${i * 90}ms`}>
            <span class="stat-value gtext">{s.value}</span>
            <span class="stat-label">{s.label}</span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ============ SERVICES ============ -->
  <section class="section services">
    <div class="container wide">
      <div class="sec-head">
        <div>
          <p class="kicker" data-reveal>What we design</p>
          <h2 class="h2" data-reveal style="--reveal-delay:80ms">Built for every kind of unforgettable.</h2>
        </div>
        <a href="/experiences" class="tlink sec-head-link" data-reveal>All experiences <span class="arrow">→</span></a>
      </div>

      <div class="svc-grid">
        {services.map((s, i) => <ServiceCard {...s} delay={i * 70} />)}
      </div>
    </div>
  </section>

  <!-- ============ CORPORATE BAND ============ -->
  <section class="section corp">
    <div class="container wide card corp-card on-grad">
      <div class="corp-glow glow" aria-hidden="true"></div>
      <div class="corp-inner">
        <div class="corp-copy">
          <p class="kicker" data-reveal>For brands & corporate teams</p>
          <h2 class="h1" data-reveal style="--reveal-delay:80ms">
            Activations that earn the <span class="font-stroke gtext">double take.</span>
          </h2>
          <p class="lede" data-reveal style="--reveal-delay:140ms">
            Product launches, conferences, galas and pop ups, produced start to finish with enterprise grade
            reliability and content ready moments your marketing team will actually want to post.
          </p>
          <ul class="corp-list" data-reveal style="--reveal-delay:200ms">
            <li>Custom branded DJ booths & on theme sound design</li>
            <li>Full production: line array sound, intelligent lighting, staging</li>
            <li>Dedicated event lead from brief to breakdown</li>
            <li>Insured, contract ready & deadline proof</li>
          </ul>
          <div data-reveal style="--reveal-delay:260ms">
            <a href="/corporate" class="btn btn-primary btn-lg">Explore corporate & brands <span class="arrow">→</span></a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ============ SHOWREEL ============ -->
  <section class="section reel">
    <div class="container wide">
      <div class="reel-head">
        <p class="kicker" data-reveal>Press play</p>
        <h2 class="h2" data-reveal style="--reveal-delay:80ms">See the <span class="font-stroke gtext">energy</span> in motion.</h2>
        <p class="lede mx-auto" data-reveal style="--reveal-delay:140ms">A quick taste of what a REmixed night feels like. The drops, the crowd, the moments.</p>
      </div>
      <Media type="video" src="/video/reel.mp4" poster="/video/reel-poster.jpg" aspect="16/9" feather={false} class="reel-frame" />
    </div>
  </section>

  <!-- ============ GALLERY ============ -->
  <section class="section tight">
    <div class="container wide">
      <div class="sec-head">
        <div>
          <p class="kicker" data-reveal>The REmixed lookbook</p>
          <h2 class="h2" data-reveal style="--reveal-delay:80ms">Moments worth reliving.</h2>
        </div>
        <a href="/contact" class="tlink sec-head-link" data-reveal>Book your moment <span class="arrow">→</span></a>
      </div>
      <div class="gallery">
        {gallery.map((g) => (
          <Media src={g.src} alt={g.alt} aspect={g.aspect} class="gallery-item" />
        ))}
      </div>
    </div>
  </section>

  <!-- ============ TESTIMONIALS ============ -->
  <section class="section">
    <div class="container wide">
      <div class="sec-head">
        <div>
          <p class="kicker" data-reveal>Word on the dance floor</p>
          <h2 class="h2" data-reveal style="--reveal-delay:80ms">Loved by clients across South Florida.</h2>
        </div>
      </div>
      <div class="quote-grid">
        {testimonials.map((t, i) => <TestimonialCard {...t} delay={i * 80} />)}
      </div>
    </div>
  </section>
</Base>

<style>
  /* ---------- HERO (video) ---------- */
  .hero {
    position: relative;
    min-height: 100svh;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    padding-top: 120px;
    padding-bottom: clamp(2.5rem, 1.5rem + 4vw, 5rem);
    overflow: hidden;
    isolation: isolate;
  }
  .hero-media { position: absolute; inset: 0; z-index: 0; }
  .hero-video { width: 100%; height: 100%; object-fit: cover; object-position: center; }
  .hero-scrim {
    position: absolute; inset: 0;
    background:
      linear-gradient(180deg, rgba(8,4,15,0.42) 0%, rgba(8,4,15,0.10) 24%, rgba(8,4,15,0.18) 55%, rgba(8,4,15,0.84) 100%),
      linear-gradient(90deg, rgba(8,4,15,0.55) 0%, rgba(8,4,15,0.08) 58%, transparent 100%);
  }
  .hero-inner { position: relative; z-index: 2; }
  .hero-kicker { margin-bottom: 1.6rem; color: #fff; }
  .hero-title { margin-bottom: clamp(1.6rem, 1rem + 3vw, 2.8rem); color: #fff; text-shadow: 0 2px 30px rgba(0,0,0,0.35); }
  .hero-title .line { display: block; }
  .hero-accent {
    background: linear-gradient(110deg, #ffffff 0%, #ffd8f6 45%, #cdb6ff 100%);
    -webkit-background-clip: text; background-clip: text; -webkit-text-fill-color: transparent;
  }
  .hero-lede { color: rgba(255,255,255,0.9); }
  .hero-lede strong { color: #fff; font-weight: 600; }
  .hero-actions { display: flex; gap: 0.8rem; flex-wrap: wrap; justify-self: start; }
  .hero-foot {
    display: grid;
    grid-template-columns: 1.1fr 0.9fr;
    gap: 2.5rem;
    align-items: end;
  }

  .hero-scroll {
    position: absolute;
    bottom: 1.4rem; left: 50%;
    transform: translateX(-50%);
    width: 26px; height: 42px;
    border: 1.5px solid rgba(255,255,255,0.5);
    border-radius: 14px;
    display: flex;
    justify-content: center;
    padding-top: 7px;
    z-index: 2;
  }
  .hero-scroll-dot {
    width: 4px; height: 8px; border-radius: 4px;
    background: #fff;
    animation: scrolldot 1.8s var(--ease) infinite;
  }
  @keyframes scrolldot { 0% { opacity: 0; transform: translateY(-4px); } 40% { opacity: 1; } 80%, 100% { opacity: 0; transform: translateY(8px); } }

  @media (max-width: 820px) {
    .hero-foot { grid-template-columns: 1fr; gap: 1.8rem; align-items: start; }
    .hero-scroll { display: none; }
  }

  /* ---------- AWARDS ---------- */
  .awards-strip { padding-block: clamp(2rem, 1.5rem + 2vw, 3rem); border-block: 1px solid var(--line); }
  .awards-label {
    text-align: center;
    font-size: 0.74rem;
    letter-spacing: 0.24em;
    text-transform: uppercase;
    color: var(--text-mute);
    margin-bottom: 1.6rem;
  }

  /* ---------- INTRO + STATS ---------- */
  .intro-grid {
    display: grid;
    grid-template-columns: 1.1fr 0.9fr;
    gap: clamp(2.5rem, 1rem + 5vw, 5rem);
    align-items: center;
  }
  .intro-copy { display: grid; gap: 1.4rem; }
  .stats {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
  }
  .stat {
    padding: clamp(1.4rem, 1rem + 1.5vw, 2.2rem);
    display: grid;
    gap: 0.4rem;
    align-content: center;
  }
  .stat-value {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: clamp(2.4rem, 1.8rem + 2.5vw, 3.6rem);
    line-height: 1;
    letter-spacing: -0.03em;
  }
  .stat-label { color: var(--text-dim); font-size: 0.92rem; }

  @media (max-width: 820px) {
    .intro-grid { grid-template-columns: 1fr; }
  }

  /* ---------- SECTION HEADINGS ---------- */
  .sec-head {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: 1.5rem;
    margin-bottom: clamp(2rem, 1.5rem + 2vw, 3.2rem);
  }
  .sec-head > div { display: grid; gap: 0.9rem; }
  .sec-head-link { padding-bottom: 0.5rem; }

  /* ---------- SERVICES GRID ---------- */
  .svc-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.2rem;
  }
  @media (max-width: 900px) { .svc-grid { grid-template-columns: repeat(2, 1fr); } }
  @media (max-width: 560px) { .svc-grid { grid-template-columns: 1fr; } .sec-head { flex-direction: column; align-items: flex-start; } }

  /* ---------- CORPORATE BAND ---------- */
  .corp-card {
    padding: clamp(2.2rem, 1.5rem + 4vw, 4.5rem);
    background: var(--grad);
    border: 0;
    overflow: hidden;
    box-shadow: 0 40px 80px -36px rgba(123, 47, 247, 0.55);
  }
  .corp-glow {
    width: 60%; height: 130%;
    top: -15%; right: -12%;
    background: radial-gradient(circle, rgba(255,255,255,0.4), transparent 65%);
    opacity: 0.55;
    filter: blur(60px);
  }
  .corp-inner { position: relative; z-index: 1; max-width: 720px; }
  .corp-copy { display: grid; gap: 1.4rem; }
  .corp-list { display: grid; gap: 0.7rem; margin: 0.3rem 0; }
  .corp-list li {
    display: flex;
    gap: 0.7rem;
    color: rgba(255, 255, 255, 0.92);
    font-size: 1rem;
  }
  .corp-list li::before {
    content: "✦";
    color: #fff;
    flex-shrink: 0;
  }

  /* ---------- SHOWREEL ---------- */
  .reel-head { text-align: center; display: grid; gap: 0.9rem; justify-items: center; max-width: 60ch; margin: 0 auto clamp(2rem, 1.5rem + 2vw, 3rem); }
  .reel :global(.reel-frame) { box-shadow: 0 50px 90px -50px rgba(123, 47, 247, 0.6); }

  /* ---------- GALLERY (masonry) ---------- */
  .gallery { columns: 3 240px; column-gap: 1.1rem; }
  .gallery :global(.gallery-item) { margin-bottom: 1.1rem; break-inside: avoid; }
  @media (max-width: 560px) { .gallery { columns: 2 150px; } }

  /* ---------- TESTIMONIALS GRID ---------- */
  .quote-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.2rem;
  }
  @media (max-width: 900px) { .quote-grid { grid-template-columns: 1fr; max-width: 560px; } }
</style>
