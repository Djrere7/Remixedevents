---
import Base from '../layouts/Base.astro';
import Marquee from '../components/Marquee.astro';
import TestimonialCard from '../components/TestimonialCard.astro';
import Media from '../components/Media.astro';
import LogoMarquee from '../components/LogoMarquee.astro';
import { testimonials, awards, site } from '../data/site';

// Homepage sells the FEELING — three visual event-category previews. The
// Experiences page carries the full service cards and the moments gallery.
const known = [
  { href: '/weddings', src: '/img/wed-sparks.jpg', k: 'Luxe Weddings', c: 'Ceremony to last dance, styled and full of life.' },
  { href: '/experiences#brand-influencer-events', src: '/img/rere-khaled-brand.jpg', k: 'Brand & Influencer Events', c: 'Female DJ energy that feels camera-ready.' },
  { href: '/experiences#special-events', src: '/img/prom-crowd.jpg', k: 'Special Events', c: 'Proms, galas, and private celebrations.' },
];
---

<Base
  fullTitle="Miami Female DJs & Event Entertainment | REmixed Events"
  description="REmixed Events is South Florida’s female DJ entertainment company for luxe weddings, brand and influencer events, yacht parties, and special events in Miami."
  heroTheme="dark"
>
  <!-- ============ HERO ============ -->
  <section class="hero">
    <div class="hero-media" aria-hidden="true">
      <div class="hero-collage">
        <video class="hero-panel" autoplay muted loop playsinline preload="metadata" poster="/video/hero-a-poster.jpg">
          <source src="/video/hero-a.mp4" type="video/mp4" />
        </video>
        <video class="hero-panel hero-panel-2" autoplay muted loop playsinline preload="metadata" poster="/video/hero-b-poster.jpg">
          <source src="/video/hero-b.mp4" type="video/mp4" />
        </video>
        <video class="hero-panel hero-panel-3" autoplay muted loop playsinline preload="metadata" poster="/video/hero-c-poster.jpg">
          <source src="/video/hero-c.mp4" type="video/mp4" />
        </video>
      </div>
      <div class="hero-scrim"></div>
    </div>

    <div class="container wide hero-inner">
      <p class="kicker hero-kicker" data-reveal>South Florida’s Female DJ Entertainment Company</p>

      <h1 class="display hero-title">
        <span class="line" data-reveal style="--reveal-delay:60ms">Not Your Ordinary</span>
        <span class="line hero-accent font-stroke" data-reveal style="--reveal-delay:180ms">DJ Company</span>
      </h1>

      <div class="hero-foot">
        <p class="lede hero-lede" data-reveal style="--reveal-delay:300ms">
          REmixed Events brings stylish female DJs, polished production, and unforgettable energy to luxe weddings,
          brand and influencer events, yacht parties, and special events across Miami, South Florida, and beyond.
        </p>
        <div class="hero-actions" data-reveal style="--reveal-delay:360ms">
          <a href={site.calendly} target="_blank" rel="noopener" class="btn btn-primary btn-lg">Schedule a Free Consultation <span class="arrow">→</span></a>
          <a href="/experiences" class="btn btn-ghost btn-lg">Explore Experiences</a>
        </div>
      </div>
    </div>

    <a href="#intro" class="hero-scroll" aria-label="Scroll to content">
      <span class="hero-scroll-dot"></span>
    </a>
  </section>

  <!-- ============ RECOGNITION TICKER ============ -->
  <section class="section tight awards-strip">
    <div class="container wide">
      <p class="awards-label">Recognized & trusted</p>
    </div>
    <Marquee items={awards} />
  </section>

  <!-- ============ BRAND LOGO STRIP ============ -->
  <section class="section tight brand-strip">
    <div class="container wide brand-strip-head">
      <h2 class="h3" data-reveal>Brands we’ve moved the room for.</h2>
      <p class="brand-strip-copy" data-reveal style="--reveal-delay:80ms">
        REmixed Events brings female DJ entertainment, polished production, and content-minded energy to brand
        moments that need to feel stylish, intentional, and camera-ready.
      </p>
    </div>
    <LogoMarquee />
  </section>

  <!-- ============ STORY (two-column) ============ -->
  <section class="section" id="intro">
    <div class="container wide story-2col">
      <div class="story-2col-copy">
        <p class="kicker" data-reveal>The REmixed Events difference</p>
        <h2 class="h2" data-reveal style="--reveal-delay:80ms">
          From rare find to <span class="font-stroke gtext">female DJ company.</span>
        </h2>
        <p data-reveal style="--reveal-delay:140ms">
          For years, DJ ReRe was the Miami female DJ people were always hoping to find. Professional, stylish,
          easy to work with, and completely in tune with the room.
        </p>
        <p data-reveal style="--reveal-delay:180ms">That became the heartbeat of REmixed Events.</p>
        <p data-reveal style="--reveal-delay:220ms">
          Today, REmixed Events is a female-led DJ entertainment company built for people who care about the
          music, the look, the flow, and the feeling of the entire event.
        </p>
      </div>
      <div class="story-2col-media" data-reveal style="--reveal-delay:160ms">
        <Media src="/img/rere-disco.jpg" alt="DJ ReRe, founder of REmixed Events" aspect="4/5" feather={false} />
      </div>
    </div>
  </section>

  <!-- ============ WHAT WE'RE KNOWN FOR (visual tiles) ============ -->
  <section class="section">
    <div class="container wide">
      <div class="sec-head">
        <div>
          <p class="kicker" data-reveal>The feeling we bring</p>
          <h2 class="h2" data-reveal style="--reveal-delay:80ms">What we’re <span class="font-stroke gtext">known for.</span></h2>
        </div>
        <a href="/experiences" class="tlink sec-head-link" data-reveal>Explore female DJ entertainment in Miami <span class="arrow">→</span></a>
      </div>
      <div class="known-grid">
        {known.map((t, i) => (
          <a class="known-tile" href={t.href} data-reveal style={`--reveal-delay:${i * 80}ms`}>
            <Media src={t.src} alt={`${t.k} by REmixed Events`} aspect="4/5" feather={false} />
            <span class="known-cap">
              <span class="known-k">{t.k}</span>
              <span class="known-c">{t.c}</span>
            </span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- ============ TESTIMONIALS ============ -->
  <section class="section">
    <div class="container wide">
      <div class="sec-head">
        <div>
          <p class="kicker" data-reveal>Straight from Google</p>
          <h2 class="h2" data-reveal style="--reveal-delay:80ms">Rated <span class="font-stroke gtext">5.0</span> by clients across South Florida.</h2>
        </div>
      </div>
      <div class="quote-grid">
        {testimonials.map((t, i) => <TestimonialCard {...t} delay={i * 80} />)}
      </div>
    </div>
  </section>

  <!-- ============ FINAL CTA ============ -->
  <section class="section">
    <div class="container wide">
      <div class="home-cta" data-reveal>
        <div class="home-cta-glow glow" aria-hidden="true"></div>
        <div class="home-cta-inner">
          <p class="kicker">Ready when you are</p>
          <h2 class="h1">Ready for a DJ company that actually <span class="font-stroke">gets it?</span></h2>
          <p class="lede">Let’s talk about your event and create an experience that feels like you — from the first song to the final moment.</p>
          <a href={site.calendly} target="_blank" rel="noopener" class="btn btn-primary btn-lg">Schedule a Free Consultation <span class="arrow">→</span></a>
          <p class="home-cta-tag font-stroke">{site.hashtag}</p>
        </div>
      </div>
    </div>
  </section>
</Base>

<style>
  /* ---------- HERO (video) ---------- */
  .hero {
    position: relative;
    min-height: 100svh;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    padding-top: 120px;
    padding-bottom: clamp(2.5rem, 1.5rem + 4vw, 5rem);
    overflow: hidden;
    isolation: isolate;
  }
  .hero-media { position: absolute; inset: 0; z-index: 0; overflow: hidden; }
  .hero-collage { position: absolute; inset: 0; display: grid; grid-template-columns: repeat(3, 1fr); gap: 0; }
  .hero-panel { width: 100%; height: 100%; object-fit: cover; object-position: center; }
  .hero-scrim {
    position: absolute; inset: 0;
    background:
      linear-gradient(180deg, rgba(8,4,15,0.5) 0%, rgba(8,4,15,0.22) 26%, rgba(8,4,15,0.32) 58%, rgba(8,4,15,0.88) 100%),
      linear-gradient(90deg, rgba(8,4,15,0.5) 0%, rgba(8,4,15,0.14) 55%, rgba(8,4,15,0.42) 100%),
      linear-gradient(120deg, rgba(123,47,247,0.34) 0%, rgba(220,30,227,0.16) 55%, rgba(42,28,232,0.24) 100%);
  }
  @media (max-width: 760px) {
    .hero-collage { grid-template-columns: 1fr; }
    .hero-panel-2, .hero-panel-3 { display: none; }
  }
  .hero-inner { position: relative; z-index: 2; }
  .hero-kicker { margin-bottom: 1.6rem; color: #fff; }
  .hero-title { margin-bottom: clamp(1.6rem, 1rem + 3vw, 2.8rem); color: #fff; text-shadow: 0 2px 30px rgba(0,0,0,0.35); }
  .hero-title .line { display: block; }
  .hero-accent {
    background: linear-gradient(110deg, #ffffff 0%, #ffd8f6 45%, #cdb6ff 100%);
    -webkit-background-clip: text; background-clip: text; -webkit-text-fill-color: transparent;
  }
  .hero-lede { color: rgba(255,255,255,0.9); }
  .hero-lede strong { color: #fff; font-weight: 600; }
  .hero-actions { display: flex; gap: 0.8rem; flex-wrap: wrap; justify-self: start; }
  .hero-foot {
    display: grid;
    grid-template-columns: 1.1fr 0.9fr;
    gap: 2.5rem;
    align-items: end;
  }

  .hero-scroll {
    position: absolute;
    bottom: 1.4rem; left: 50%;
    transform: translateX(-50%);
    width: 26px; height: 42px;
    border: 1.5px solid rgba(255,255,255,0.5);
    border-radius: 14px;
    display: flex;
    justify-content: center;
    padding-top: 7px;
    z-index: 2;
  }
  .hero-scroll-dot {
    width: 4px; height: 8px; border-radius: 4px;
    background: #fff;
    animation: scrolldot 1.8s var(--ease) infinite;
  }
  @keyframes scrolldot { 0% { opacity: 0; transform: translateY(-4px); } 40% { opacity: 1; } 80%, 100% { opacity: 0; transform: translateY(8px); } }

  @media (max-width: 820px) {
    .hero-foot { grid-template-columns: 1fr; gap: 1.8rem; align-items: start; }
    .hero-scroll { display: none; }
  }

  /* ---------- AWARDS ---------- */
  .awards-strip { padding-block: clamp(2rem, 1.5rem + 2vw, 3rem); border-block: 1px solid var(--line); }
  .awards-label {
    text-align: center;
    font-size: 0.74rem;
    letter-spacing: 0.24em;
    text-transform: uppercase;
    color: var(--text-mute);
    margin-bottom: 1.6rem;
  }

  /* ---------- INTRO + STATS ---------- */
  .intro-grid {
    display: grid;
    grid-template-columns: 1.1fr 0.9fr;
    gap: clamp(2.5rem, 1rem + 5vw, 5rem);
    align-items: center;
  }
  .intro-copy { display: grid; gap: 1.4rem; }
  .stats {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
  }
  .stat {
    padding: clamp(1.4rem, 1rem + 1.5vw, 2.2rem);
    display: grid;
    gap: 0.4rem;
    align-content: center;
  }
  .stat-value {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: clamp(2.4rem, 1.8rem + 2.5vw, 3.6rem);
    line-height: 1;
    letter-spacing: -0.03em;
  }
  .stat-label { color: var(--text-dim); font-size: 0.92rem; }

  @media (max-width: 820px) {
    .intro-grid { grid-template-columns: 1fr; }
  }

  /* ---------- SECTION HEADINGS ---------- */
  .sec-head {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: 1.5rem;
    margin-bottom: clamp(2rem, 1.5rem + 2vw, 3.2rem);
  }
  .sec-head > div { display: grid; gap: 0.9rem; }
  .sec-head-link { padding-bottom: 0.5rem; }

  .brand-strip { padding-top: 0 !important; }
  .brand-strip-head { max-width: 640px; margin: 0 auto 1.8rem; text-align: center; display: grid; gap: 0.7rem; }
  .brand-strip-copy { color: var(--text-dim); font-size: 0.98rem; }

  /* ---------- STORY (two column) ---------- */
  .story-2col {
    display: grid;
    grid-template-columns: 1.05fr 0.95fr;
    gap: clamp(2rem, 1rem + 4vw, 4.5rem);
    align-items: center;
  }
  .story-2col-copy { display: grid; gap: 1.1rem; }
  .story-2col-copy p { color: var(--text-dim); font-size: clamp(1.02rem, 0.98rem + 0.3vw, 1.18rem); max-width: 46ch; }
  .story-2col-media { max-width: 480px; justify-self: end; width: 100%; }
  @media (max-width: 820px) {
    .story-2col { grid-template-columns: 1fr; gap: 1.8rem; }
    .story-2col-media { justify-self: start; max-width: 380px; order: 2; }
    .story-2col-copy p { font-size: 1rem; }
  }

  /* ---------- ABOUT PREVIEW ---------- */
  .about-prev {
    display: grid;
    grid-template-columns: 0.9fr 1.1fr;
    gap: clamp(2rem, 1rem + 4vw, 4rem);
    align-items: center;
  }
  .about-prev-copy { display: grid; gap: 1.2rem; justify-items: start; }
  .about-prev-photos { display: grid; grid-template-columns: repeat(3, 1fr); gap: 0.8rem; }
  @media (max-width: 820px) {
    .about-prev { grid-template-columns: 1fr; gap: 1.8rem; }
  }
  @media (max-width: 480px) {
    .about-prev-photos { gap: 0.55rem; }
  }

  /* ---------- WHAT WE'RE KNOWN FOR (tiles) ---------- */
  .known-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1.1rem; }
  .known-tile {
    position: relative;
    display: block;
    border-radius: calc(var(--radius) + 4px);
    overflow: hidden;
    box-shadow: 0 22px 48px -30px rgba(40, 16, 80, 0.4);
    transition: transform 0.4s var(--ease), box-shadow 0.4s var(--ease);
  }
  .known-tile:hover { transform: translateY(-4px); box-shadow: 0 34px 60px -34px rgba(123, 47, 247, 0.5); }
  .known-tile :global(.media) { border-radius: 0; box-shadow: none; }
  .known-cap {
    position: absolute; left: 0; right: 0; bottom: 0; z-index: 2;
    display: grid; gap: 0.25rem;
    padding: 2.8rem 1.2rem 1.15rem;
    background: linear-gradient(to top, rgba(8,4,15,0.86), rgba(8,4,15,0.25) 55%, transparent);
    pointer-events: none;
  }
  .known-k { font-family: var(--font-display); font-size: 1.25rem; font-weight: 600; letter-spacing: -0.01em; color: #fff; }
  .known-c { font-size: 0.92rem; color: rgba(255,255,255,0.88); }
  @media (max-width: 820px) { .known-grid { grid-template-columns: 1fr 1fr; gap: 0.8rem; } }
  @media (max-width: 640px) {
    .sec-head { flex-direction: column; align-items: flex-start; }
    /* Prioritise the visual on mobile: caption drops below the image */
    .known-tile { background: var(--surface); }
    .known-cap { position: static; padding: 0.6rem 0.5rem 0.7rem; background: none; }
    .known-k { color: var(--text); }
    .known-c { color: var(--text-dim); }
  }

  /* ---------- CORPORATE BAND ---------- */
  .corp-card {
    padding: clamp(2.2rem, 1.5rem + 4vw, 4.5rem);
    background: var(--grad);
    border: 0;
    overflow: hidden;
    box-shadow: 0 40px 80px -36px rgba(123, 47, 247, 0.55);
  }
  .corp-glow {
    width: 60%; height: 130%;
    top: -15%; right: -12%;
    background: radial-gradient(circle, rgba(255,255,255,0.4), transparent 65%);
    opacity: 0.55;
    filter: blur(60px);
  }
  .corp-inner { position: relative; z-index: 1; max-width: 720px; }
  .corp-copy { display: grid; gap: 1.4rem; }
  .corp-list { display: grid; gap: 0.7rem; margin: 0.3rem 0; }
  .corp-list li {
    display: flex;
    gap: 0.7rem;
    color: rgba(255, 255, 255, 0.92);
    font-size: 1rem;
  }
  .corp-list li::before {
    content: "✦";
    color: #fff;
    flex-shrink: 0;
  }

  /* ---------- SHOWREEL ---------- */
  .reel-head { text-align: center; display: grid; gap: 0.9rem; justify-items: center; max-width: 60ch; margin: 0 auto clamp(2rem, 1.5rem + 2vw, 3rem); }
  .reel :global(.reel-frame) { box-shadow: 0 50px 90px -50px rgba(123, 47, 247, 0.6); }

  /* ---------- EVENTS WE LOVE ---------- */
  .center-head-x { text-align: center; display: grid; gap: 0.9rem; justify-items: center; max-width: 44ch; margin: 0 auto clamp(2rem, 1.5rem + 2vw, 3rem); }
  .evt-chips { display: flex; flex-wrap: wrap; gap: 0.6rem; justify-content: center; max-width: 940px; margin: 0 auto; }
  .evt-chip { font-size: 0.92rem; padding: 0.6em 1.1em; }

  /* ---------- GALLERY (masonry) ---------- */
  .gallery { columns: 3 240px; column-gap: 1.1rem; }
  .gallery-item {
    margin: 0 0 1.1rem;
    break-inside: avoid;
    position: relative;
    border-radius: calc(var(--radius) + 4px);
    overflow: hidden;
    box-shadow: 0 22px 48px -30px rgba(40, 16, 80, 0.4);
  }
  .gcap-label {
    position: absolute;
    left: 0; right: 0; bottom: 0;
    z-index: 2;
    display: grid;
    gap: 0.3rem;
    padding: 2.6rem 1.15rem 1.1rem;
    background: linear-gradient(to top, rgba(8, 4, 15, 0.85), rgba(8, 4, 15, 0.25) 55%, transparent);
    pointer-events: none;
  }
  .gcap-k { font-size: 0.68rem; font-weight: 700; letter-spacing: 0.18em; text-transform: uppercase; color: #fff; }
  .gcap-c { font-family: var(--font-serif); font-style: italic; font-size: 0.95rem; line-height: 1.35; color: rgba(255,255,255,0.92); }
  @media (max-width: 560px) { .gallery { columns: 2 150px; } }

  /* ---------- TESTIMONIALS GRID ---------- */
  .quote-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.2rem;
  }
  @media (max-width: 900px) { .quote-grid { grid-template-columns: 1fr; max-width: 560px; } }

  /* ---------- FINAL CTA ---------- */
  .home-cta {
    position: relative;
    padding: clamp(2.5rem, 1.5rem + 5vw, 5rem);
    text-align: center;
    border-radius: calc(var(--radius) + 8px);
    background: var(--grad);
    overflow: hidden;
    isolation: isolate;
    box-shadow: 0 40px 80px -36px rgba(123, 47, 247, 0.55);
  }
  .home-cta-glow { width: 70%; height: 90%; top: -25%; left: 15%; background: radial-gradient(circle, rgba(255,255,255,0.45), transparent 65%); opacity: 0.55; filter: blur(60px); }
  .home-cta-inner { position: relative; z-index: 1; display: grid; gap: 1.3rem; justify-items: center; }
  .home-cta-inner .h1 { color: #fff; max-width: 20ch; }
  .home-cta-inner .lede { color: rgba(255,255,255,0.92); max-width: 52ch; margin-inline: auto; }
  .home-cta-inner .btn-primary { background: #fff; color: var(--violet); }
  .home-cta-tag { color: #fff; font-size: clamp(1.4rem, 1.1rem + 1.4vw, 2.1rem); margin-top: 0.3rem; opacity: 0.95; }
</style>
