---
import Base from '../layouts/Base.astro';
import PageHeader from '../components/PageHeader.astro';
import Media from '../components/Media.astro';
import Marquee from '../components/Marquee.astro';
import { eventTypes, awards, site } from '../data/site';

const process = [
  { n: '01', t: 'Tell us the vision', d: 'We learn about your event, your people, your music style and the feeling you want in the room.' },
  { n: '02', t: 'We curate the experience', d: 'We recommend the right DJ, sound direction, production needs and event flow.' },
  { n: '03', t: 'We handle the details', d: 'Our team manages setup, soundcheck, timing and communication so everything feels smooth.' },
  { n: '04', t: 'You enjoy the moment', d: 'We read the room, lead the energy and keep the celebration moving.' },
];

// Concise visual nav — previews the categories and jumps to each section.
const navCards = [
  { href: '/weddings', img: '/img/sparks-clouds.jpg', t: 'Luxe Weddings', d: 'Ceremony to last dance.' },
  { href: '#brand-influencer-events', img: '/img/branded-dove-carpet.jpg', t: 'Branded Moments', d: 'Brand & influencer events.' },
  { href: '#special-events', img: '/img/prom-ibe-breakdance.jpg', t: 'Special Events', d: 'Proms, galas & celebrations.' },
  { href: '#production-enhancements', img: '/img/cold-sparks.jpg', t: 'Production & Enhancements', d: 'Sparks, clouds, booths & lighting.' },
];

// Each category is a media-rich section: video(s) + photos, real folder media.
const categories = [
  {
    id: 'brand-influencer-events',
    eyebrow: 'Brand & Influencer Events',
    title: 'Branded Moments.',
    copy: 'When your brand is in the room, every detail matters. We bring female DJs, hosts, creators, sound, lighting, and content-minded energy to launches, pop-ups, brand dinners, and influencer events that need to feel polished, intentional, and camera-ready.',
    videos: [
      { src: '/video/corp.mp4', poster: '/video/corp-poster.jpg', aspect: '16/9', cap: 'Dove Brand Event — female DJ entertainment, uplighting, and branded energy by REmixed Events.' },
    ],
    photos: [
      { src: '/img/branded-dove2.jpg', alt: 'REmixed Events DJ on the decks at the Dove event', cap: 'Dove — on the decks' },
      { src: '/img/branded-dove7.jpg', alt: 'A beachside branded activation by REmixed Events', cap: 'Beachside brand activation' },
      { src: '/img/brand-fenty.jpg', alt: 'Savage X Fenty brand activation by REmixed Events', cap: 'Savage X Fenty' },
      { src: '/img/brand-kors.jpg', alt: 'Michael Kors in-store activation by REmixed Events', cap: 'Michael Kors' },
      { src: '/img/activation-aero.jpg', alt: 'Aéropostale and Cheetos pop-up booth by REmixed Events', cap: 'Aéropostale × Cheetos' },
      { src: '/img/corp-team.jpg', alt: 'The REmixed Events team at a corporate brand event', cap: 'The team on-site' },
    ],
    link: { href: '/corporate', label: 'See the full brand & influencer page' },
  },
  {
    id: 'special-events',
    eyebrow: 'Special Events',
    title: 'Proms, galas, and nights to remember.',
    copy: 'Female DJs for proms, school dances, galas, milestone celebrations, private events, and luxury dinners. Our DJs do more than play music — they read the room, hop on the mic, and bring the personality. Yacht and boat celebrations available on request.',
    videos: [
      { src: '/video/wedding-neeek.mp4', poster: '/video/wedding-neeek-poster.jpg', aspect: '16/9', cap: 'DJ Neeek and a packed floor in full swing at a REmixed Events celebration.' },
    ],
    photos: [
      { src: '/img/prom-breakdance.jpg', alt: 'A dancer breaking in the middle of the floor at a prom by REmixed Events', cap: 'Prom — the floor opens up' },
      { src: '/img/school-dance3.jpg', alt: 'Students dancing and celebrating at a school dance by REmixed Events', cap: 'School dance dance floor' },
      { src: '/img/prom-hype.jpg', alt: 'DJ IB hyping the crowd on the mic at a prom', cap: 'DJ IB working the crowd' },
      { src: '/img/youth-dj.jpg', alt: 'REmixed Events female DJs at a youth First Spin event', cap: 'Youth DJ programs & school events' },
      { src: '/img/special-prom.jpg', alt: 'A REmixed Events school dance celebration', cap: 'School dances & socials' },
      { src: '/img/clouds-sweet16.jpg', alt: 'A Sweet 16 dancing on the clouds by REmixed Events', cap: 'Dancing on Clouds — Sweet 16' },
    ],
    link: null,
  },
  {
    id: 'production-enhancements',
    eyebrow: 'Production & Enhancements',
    title: 'The details that make the room feel complete.',
    copy: 'The music matters, but so does the way the room looks, sounds, and feels. Cold sparks, dancing on clouds, photo booths, custom DJ booths, uplighting, and sound — we bring the enhancements that make an event feel polished from the first guest to the final song.',
    videos: [
      { src: '/video/photobooth.mp4', poster: '/video/photobooth-poster.jpg', aspect: '4/5', cap: 'Photo Booth Moments — fun, stylish, and guest-approved.' },
    ],
    photos: [
      { src: '/img/wed-clouds.jpg', alt: 'Dancing on clouds first-dance effect by REmixed Events', cap: 'Dancing on Clouds' },
      { src: '/img/booth-setup.jpg', alt: 'A custom REmixed Events DJ booth setup', cap: 'DJ booths & facades' },
      { src: '/img/uplights-wedding.jpg', alt: 'An elegant ballroom with amber uplighting by REmixed Events', cap: 'Lighting & ambiance' },
      { src: '/img/wed-cocktail.jpg', alt: 'A wedding cocktail and reception space styled with uplighting by REmixed Events', cap: 'Cocktail & reception ambiance' },
      { src: '/img/production-sparks.jpg', alt: 'Cold spark fountains at a REmixed Events event', cap: 'Cold sparks' },
      { src: '/img/production.jpg', alt: 'A completed REmixed Events production setup', cap: 'Full production setups' },
    ],
    link: null,
  },
];

// REmixed Events Moments — the main visual portfolio (moved from the homepage).
const gallery = [
  { src: '/img/branded-dove-lounge.jpg', label: 'Brand Event Energy', alt: 'The Dove Miami Beach event lounge by REmixed Events', aspect: '4/3' },
  { src: '/img/wed-party-dance.jpg', label: 'Wedding Dance Floors', alt: 'A packed wedding reception dance floor under string lights', aspect: '4/5' },
  { src: '/img/corp-team4.jpg', label: 'The Team On-Site', alt: 'The REmixed Events team at a corporate event', aspect: '4/3' },
  { src: '/img/female-djs.jpg', label: 'Female DJs', alt: 'The women of REmixed Events at an event', aspect: '4/3' },
  { src: '/img/dj-outdoor.jpg', label: 'Brand Activations', alt: 'A REmixed Events female DJ at an ACC brand activation', aspect: '4/5' },
  { src: '/img/corporate-acc.jpg', label: 'On-Brand Setups', alt: 'ACC branded activation tent by REmixed Events', aspect: '4/3' },
  { src: '/img/wed-team-carlos.jpg', label: 'Behind the Scenes', alt: 'The REmixed Events team behind the scenes at an event', aspect: '4/3' },
  { src: '/img/brand-lids.jpg', label: 'Custom DJ Booths', alt: 'A custom LIDS activation DJ booth by REmixed Events', aspect: '4/5' },
  { src: '/img/branded-dove-activation.jpg', label: 'Pop-Ups & Launches', alt: 'A branded product activation table by REmixed Events', aspect: '4/3' },
];
---

<Base
  fullTitle="Female DJ Entertainment in Miami | Weddings, Brands & Events"
  description="Explore female DJ entertainment in Miami for luxe weddings, brand events, influencer events, proms, school dances, private celebrations, and special events."
>
  <PageHeader
    kicker="What we curate"
    title="Miami female DJ entertainment for"
    emphasis="unforgettable events."
    emphasisClass="font-stroke"
    lede="REmixed Events brings stylish female DJs, polished production, and unforgettable energy to luxe weddings, brand and influencer events, proms, and special events across Miami, South Florida, and beyond. We listen first, then build the music, hosting, sound, lighting, and production around the room."
  />

  <!-- CATEGORY NAV CARDS (preview + jump to sections) -->
  <section class="section tight">
    <div class="container wide">
      <div class="nav-cards">
        {navCards.map((c, i) => (
          <a class="nav-card" href={c.href} data-reveal style={`--reveal-delay:${i * 60}ms`}>
            <Media src={c.img} alt={`${c.t} by REmixed Events`} aspect="5/4" feather={false} />
            <span class="nav-card-body">
              <span class="nav-card-t">{c.t}</span>
              <span class="nav-card-d">{c.d}</span>
              <span class="nav-card-arrow gtext" aria-hidden="true">→</span>
            </span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- CATEGORY DEEP-DIVES -->
  {categories.map((cat) => (
    <section class="section exp-cat" id={cat.id}>
      <div class="container wide">
        <div class="sec-head">
          <div>
            <p class="kicker" data-reveal>{cat.eyebrow}</p>
            <h2 class="h2" data-reveal style="--reveal-delay:80ms">{cat.title}</h2>
            <p class="lede" data-reveal style="--reveal-delay:140ms">{cat.copy}</p>
          </div>
          {cat.link && <a href={cat.link.href} class="tlink sec-head-link" data-reveal>{cat.link.label} <span class="arrow">→</span></a>}
        </div>

        <div class="exp-media">
          <div class="exp-videos">
            {cat.videos.map((v) => (
              <figure class="exp-fig" data-reveal>
                <Media type="video" src={v.src} poster={v.poster} aspect={v.aspect} feather={false} />
                <figcaption class="exp-cap">{v.cap}</figcaption>
              </figure>
            ))}
          </div>
          <div class="exp-photos">
            {cat.photos.map((p, i) => (
              <figure class="exp-fig" data-reveal style={`--reveal-delay:${i * 50}ms`}>
                <Media src={p.src} alt={p.alt} aspect="4/3" feather={false} />
                <figcaption class="exp-cap">{p.cap}</figcaption>
              </figure>
            ))}
          </div>
        </div>
      </div>
    </section>
  ))}

  <!-- REMIXED EVENTS MOMENTS (portfolio gallery) -->
  <section class="section tight">
    <div class="container wide">
      <div class="sec-head">
        <div>
          <p class="kicker" data-reveal>The portfolio</p>
          <h2 class="h2" data-reveal style="--reveal-delay:80ms">REmixed Events Moments</h2>
          <p class="lede" data-reveal style="--reveal-delay:120ms">Real events. Real dance floors. Real moments brought to life by REmixed Events.</p>
        </div>
      </div>
      <div class="gallery">
        {gallery.map((g) => (
          <figure class="gallery-item" data-reveal>
            <Media src={g.src} alt={g.alt} aspect={g.aspect} feather={false} />
            <figcaption class="gcap-label"><span class="gcap-k">{g.label}</span></figcaption>
          </figure>
        ))}
      </div>
    </div>
  </section>

  <!-- PROCESS -->
  <section class="section section-light">
    <div class="container wide">
      <div class="sec-head">
        <div>
          <p class="kicker" data-reveal>How it works</p>
          <h2 class="h2" data-reveal style="--reveal-delay:80ms">A smooth process from vision to <span class="font-stroke gtext">final song.</span></h2>
        </div>
      </div>
      <div class="proc-grid">
        {process.map((p, i) => (
          <div class="proc card" data-reveal style={`--reveal-delay:${i * 80}ms`}>
            <span class="proc-n gtext">{p.n}</span>
            <h3 class="proc-t">{p.t}</h3>
            <p class="proc-d">{p.d}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- EVENT TYPES -->
  <section class="section tight">
    <div class="container wide">
      <p class="kicker center mx-auto" data-reveal style="display:flex;justify-content:center">Events we love</p>
      <div class="types" data-reveal style="--reveal-delay:80ms">
        {eventTypes.map((t) => <span class="chip type-chip">{t}</span>)}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="section tight">
    <div class="container wide">
      <div class="exp-cta-bar" data-reveal>
        <div class="exp-cta-glow glow" aria-hidden="true"></div>
        <div class="exp-cta-text">
          <p class="kicker">Let’s talk</p>
          <h2 class="h2">Let’s find the right fit for <span class="font-stroke">your event.</span></h2>
          <p class="lede">Tell us what you’re planning, and we’ll help match the female DJ entertainment, production, and energy to the moment.</p>
          <p class="exp-cta-tag font-stroke">{site.hashtag}</p>
        </div>
        <a href={site.calendly} target="_blank" rel="noopener" class="btn btn-primary btn-lg exp-cta-btn">Schedule a Free Consultation <span class="arrow">→</span></a>
      </div>
    </div>
  </section>

  <section class="section tight awards-band">
    <Marquee items={awards} speed={28} />
  </section>
</Base>

<style>
  /* Concise nav cards */
  .nav-cards { display: grid; grid-template-columns: repeat(4, 1fr); gap: 1.1rem; }
  .nav-card { position: relative; display: block; border-radius: calc(var(--radius) + 4px); overflow: hidden; box-shadow: 0 22px 48px -30px rgba(40, 16, 80, 0.4); transition: transform 0.35s var(--ease), box-shadow 0.35s var(--ease); }
  .nav-card:hover { transform: translateY(-4px); box-shadow: 0 34px 60px -34px rgba(123, 47, 247, 0.5); }
  .nav-card :global(.media) { border-radius: 0; box-shadow: none; }
  .nav-card-body { position: absolute; left: 0; right: 0; bottom: 0; z-index: 2; display: grid; gap: 0.1rem; padding: 2.4rem 1rem 0.95rem; background: linear-gradient(to top, rgba(8,4,15,0.9), rgba(8,4,15,0.2) 60%, transparent); pointer-events: none; }
  .nav-card-t { font-family: var(--font-display); font-size: 1.12rem; font-weight: 600; color: #fff; letter-spacing: -0.01em; }
  .nav-card-d { font-size: 0.85rem; color: rgba(255,255,255,0.85); }
  .nav-card-arrow { position: absolute; top: 0.9rem; right: 1rem; font-size: 1.1rem; color: #fff; }
  @media (max-width: 820px) { .nav-cards { grid-template-columns: 1fr 1fr; } }
  @media (max-width: 560px) {
    /* Caption below the image so words never cover the photo */
    .nav-card { background: var(--surface); }
    .nav-card-body { position: static; padding: 0.55rem 0.6rem 0.7rem; background: none; }
    .nav-card-t { color: var(--text); }
    .nav-card-d { color: var(--text-dim); }
    .nav-card-arrow { color: var(--violet); }
  }

  .sec-head { display: flex; align-items: flex-end; justify-content: space-between; gap: 1.5rem; margin-bottom: clamp(2rem, 1.5rem + 2vw, 3rem); }
  .sec-head > div { display: grid; gap: 0.9rem; max-width: 64ch; }
  .sec-head-link { padding-bottom: 0.4rem; white-space: nowrap; }
  @media (max-width: 700px) { .sec-head { flex-direction: column; align-items: flex-start; } }

  /* Category deep-dive media */
  .exp-cat { scroll-margin-top: 90px; }
  .exp-media { display: grid; grid-template-columns: 1fr 1fr; gap: clamp(1.1rem, 0.8rem + 1.5vw, 1.8rem); align-items: start; }
  .exp-videos { display: grid; gap: 1rem; align-content: start; }
  .exp-photos { display: grid; grid-template-columns: 1fr 1fr; gap: 0.9rem; }
  .exp-fig { display: grid; gap: 0.45rem; margin: 0; }
  .exp-cap { font-size: 0.85rem; color: var(--text-mute); line-height: 1.4; }
  @media (max-width: 820px) { .exp-media { grid-template-columns: 1fr; } }

  /* Portfolio gallery (masonry) */
  .gallery { columns: 3 240px; column-gap: 1.1rem; }
  .gallery-item { margin: 0 0 1.1rem; break-inside: avoid; position: relative; border-radius: calc(var(--radius) + 4px); overflow: hidden; box-shadow: 0 22px 48px -30px rgba(40, 16, 80, 0.4); }
  .gcap-label { position: absolute; left: 0; right: 0; bottom: 0; z-index: 2; padding: 2.4rem 1.1rem 0.95rem; background: linear-gradient(to top, rgba(8,4,15,0.85), rgba(8,4,15,0.15) 60%, transparent); pointer-events: none; }
  .gcap-k { font-size: 0.68rem; font-weight: 700; letter-spacing: 0.18em; text-transform: uppercase; color: #fff; }
  @media (max-width: 560px) { .gallery { columns: 2 150px; } }

  .proc-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 1.1rem; }
  .proc { padding: 1.8rem 1.5rem; display: grid; gap: 0.6rem; align-content: start; }
  .proc-n { font-family: var(--font-display); font-weight: 700; font-size: 2rem; letter-spacing: -0.03em; }
  .proc-t { font-family: var(--font-display); font-size: 1.2rem; font-weight: 600; }
  .proc-d { color: var(--cream-dim); font-size: 0.93rem; }
  @media (max-width: 820px) { .proc-grid { grid-template-columns: 1fr 1fr; } }
  @media (max-width: 480px) { .proc-grid { grid-template-columns: 1fr; } }

  .types { display: flex; flex-wrap: wrap; gap: 0.6rem; justify-content: center; max-width: 880px; margin: 1.6rem auto 0; }
  .type-chip { font-size: 0.92rem; padding: 0.6em 1.1em; }

  /* Full-width CTA bar */
  .exp-cta-bar { position: relative; display: grid; grid-template-columns: 1.5fr auto; gap: clamp(1.5rem, 1rem + 3vw, 3.5rem); align-items: center; padding: clamp(2rem, 1.4rem + 3vw, 3.6rem); border-radius: calc(var(--radius) + 8px); background: var(--grad); overflow: hidden; isolation: isolate; box-shadow: 0 40px 80px -40px rgba(123, 47, 247, 0.55); }
  .exp-cta-glow { width: 55%; height: 130%; top: -15%; right: -8%; background: radial-gradient(circle, rgba(255,255,255,0.4), transparent 65%); opacity: 0.5; filter: blur(60px); }
  .exp-cta-text { position: relative; z-index: 1; display: grid; gap: 0.8rem; max-width: 48ch; }
  .exp-cta-text .kicker, .exp-cta-text .h2 { color: #fff; }
  .exp-cta-text .lede { color: rgba(255,255,255,0.9); }
  .exp-cta-tag { color: #fff; font-size: 1.4rem; margin-top: 0.2rem; }
  .exp-cta-btn { position: relative; z-index: 1; background: #fff; color: var(--violet); }
  @media (max-width: 760px) { .exp-cta-bar { grid-template-columns: 1fr; } }

  .awards-band { border-top: 1px solid var(--line); }
</style>
