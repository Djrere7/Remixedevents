---
import Base from '../layouts/Base.astro';
import PageHeader from '../components/PageHeader.astro';
import ServiceCard from '../components/ServiceCard.astro';
import Media from '../components/Media.astro';
import Marquee from '../components/Marquee.astro';
import { services, eventTypes, awards, site } from '../data/site';

const process = [
  { n: '01', t: 'Tell us the vision', d: 'We learn about your event, your people, your music style and the feeling you want in the room.' },
  { n: '02', t: 'We curate the experience', d: 'We recommend the right DJ, sound direction, production needs and event flow.' },
  { n: '03', t: 'We handle the details', d: 'Our team manages setup, soundcheck, timing and communication so everything feels smooth.' },
  { n: '04', t: 'You enjoy the moment', d: 'We read the room, lead the energy and keep the celebration moving.' },
];

// Each category gets its own anchored, media-rich section: a video + four photos.
const categories = [
  {
    id: 'brand-influencer-events',
    eyebrow: 'Brand & Influencer Events',
    title: 'Brand moments, remixed.',
    copy: 'When your brand is in the room, every detail matters. We bring female DJs, hosts, creators, sound, lighting, and content-minded energy to launches, pop-ups, brand dinners, and influencer events that need to feel polished, intentional, and camera-ready.',
    videos: [
      { src: '/video/corp.mp4', poster: '/video/corp-poster.jpg', aspect: '16/9', cap: 'Dove Brand Event — female DJ entertainment, uplighting, and branded energy by REmixed Events.' },
    ],
    photos: [
      { src: '/img/brand-fenty.jpg', alt: 'Savage X Fenty brand activation by REmixed Events', cap: 'Savage X Fenty activation' },
      { src: '/img/activation-aero.jpg', alt: 'Aéropostale and Cheetos pop-up booth by REmixed Events', cap: 'Aéropostale × Cheetos pop-up' },
      { src: '/img/brand-kors.jpg', alt: 'Michael Kors in-store activation by REmixed Events', cap: 'Michael Kors in-store' },
      { src: '/img/dj-outdoor.jpg', alt: 'Female DJ at an ACC × ESPN activation by REmixed Events', cap: 'ACC × ESPN activation' },
    ],
    link: { href: '/corporate', label: 'See the full brand & influencer page' },
  },
  {
    id: 'special-events',
    eyebrow: 'Special Events',
    title: 'Yacht parties, galas, and nights to remember.',
    copy: 'Female DJs for yacht parties, boat parties, milestone celebrations, private events, luxury dinners, proms, and galas that deserve real personality and a floor that stays full.',
    videos: [
      { src: '/video/hero-c.mp4', poster: '/video/hero-c-poster.jpg', aspect: '4/5', cap: 'DJ party moment — a packed floor by REmixed Events.' },
    ],
    photos: [
      { src: '/img/led-pool.jpg', alt: 'Poolside Miami night celebration by REmixed Events', cap: 'Poolside Miami nights' },
      { src: '/img/special-prom.jpg', alt: 'Prom and school event by REmixed Events', cap: 'Proms & school events' },
      { src: '/img/rere-khaled.jpg', alt: 'DJ ReRe at a celebrity event', cap: 'Celebrity & VIP moments' },
      { src: '/img/rere-disco.jpg', alt: 'DJ ReRe styled for a private celebration', cap: 'Private celebrations' },
    ],
    link: null,
  },
  {
    id: 'production-enhancements',
    eyebrow: 'Production & Enhancements',
    title: 'The details that make the room feel complete.',
    copy: 'The music matters, but so does the way the room looks, sounds, and feels. From photo booths to cold sparks, uplighting to dancing on clouds, we help your event feel polished from the first guest arrival to the final song.',
    videos: [
      { src: '/video/photobooth.mp4', poster: '/video/photobooth-poster.jpg', aspect: '4/5', cap: 'Photo Booth Moments — fun, stylish, and guest-approved.' },
      { src: '/video/wed-hero.mp4', poster: '/video/wed-hero-poster.jpg', aspect: '16/9', cap: 'Cold Spark Moments — venue-approved sparks for entrances and first dances.' },
    ],
    photos: [
      { src: '/img/wed-clouds.jpg', alt: 'Dancing on clouds first-dance effect by REmixed Events', cap: 'Dancing on Clouds — a dreamy first-dance effect.' },
      { src: '/img/venue-uplights.jpg', alt: 'Uplighting and ambiance by REmixed Events', cap: 'Uplighting & Ambiance — color, glow, atmosphere.' },
      { src: '/img/production-lights.jpg', alt: 'Lighting and production by REmixed Events', cap: 'Lighting & production' },
      { src: '/img/booth-setup.jpg', alt: 'DJ booth and sound setup by REmixed Events', cap: 'DJ booths & sound' },
    ],
    link: null,
  },
];
---

<Base
  fullTitle="Female DJ Entertainment in Miami | Weddings, Brands & Events"
  description="Explore female DJ entertainment in Miami for luxe weddings, brand events, influencer events, yacht parties, private celebrations, and special events."
>
  <PageHeader
    kicker="What we curate"
    title="Miami female DJ entertainment for"
    emphasis="unforgettable events."
    emphasisClass="font-stroke"
    lede="REmixed Events brings stylish female DJs, polished production, and unforgettable energy to luxe weddings, brand and influencer events, yacht parties, and special events across Miami, South Florida, and beyond. We listen first, then build the music, hosting, sound, lighting, and production around the room."
  />

  <!-- CATEGORY CARDS (jump to sections) -->
  <section class="section tight">
    <div class="container wide">
      <div class="svc-grid">
        {services.map((s, i) => <ServiceCard {...s} delay={i * 60} />)}
      </div>
    </div>
  </section>

  <!-- CATEGORY DEEP-DIVES (anchored, media-rich) -->
  {categories.map((cat) => (
    <section class="section exp-cat" id={cat.id}>
      <div class="container wide">
        <div class="sec-head">
          <div>
            <p class="kicker" data-reveal>{cat.eyebrow}</p>
            <h2 class="h2" data-reveal style="--reveal-delay:80ms">{cat.title}</h2>
            <p class="lede" data-reveal style="--reveal-delay:140ms">{cat.copy}</p>
          </div>
          {cat.link && <a href={cat.link.href} class="tlink sec-head-link" data-reveal>{cat.link.label} <span class="arrow">→</span></a>}
        </div>

        <div class="exp-media">
          <div class="exp-videos">
            {cat.videos.map((v) => (
              <div class="exp-fig" data-reveal>
                <Media type="video" src={v.src} poster={v.poster} aspect={v.aspect} feather={false} />
                <p class="exp-cap">{v.cap}</p>
              </div>
            ))}
          </div>
          <div class="exp-photos">
            {cat.photos.map((p, i) => (
              <div class="exp-fig" data-reveal style={`--reveal-delay:${i * 60}ms`}>
                <Media src={p.src} alt={p.alt} aspect="4/3" feather={false} />
                <p class="exp-cap">{p.cap}</p>
              </div>
            ))}
          </div>
        </div>
      </div>
    </section>
  ))}

  <!-- PROCESS -->
  <section class="section section-light">
    <div class="container wide">
      <div class="sec-head">
        <div>
          <p class="kicker" data-reveal>How it works</p>
          <h2 class="h2" data-reveal style="--reveal-delay:80ms">A smooth process from vision to <span class="font-stroke gtext">final song.</span></h2>
        </div>
      </div>
      <div class="proc-grid">
        {process.map((p, i) => (
          <div class="proc card" data-reveal style={`--reveal-delay:${i * 80}ms`}>
            <span class="proc-n gtext">{p.n}</span>
            <h3 class="proc-t">{p.t}</h3>
            <p class="proc-d">{p.d}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- EVENT TYPES -->
  <section class="section tight">
    <div class="container wide">
      <p class="kicker center mx-auto" data-reveal style="display:flex;justify-content:center">Events we love</p>
      <div class="types" data-reveal style="--reveal-delay:80ms">
        {eventTypes.map((t) => <span class="chip type-chip">{t}</span>)}
      </div>
    </div>
  </section>

  <!-- CTA (full-width bar) -->
  <section class="section tight">
    <div class="container wide">
      <div class="exp-cta-bar" data-reveal>
        <div class="exp-cta-glow glow" aria-hidden="true"></div>
        <div class="exp-cta-text">
          <p class="kicker">Let’s talk</p>
          <h2 class="h2">Let’s find the right fit for <span class="font-stroke">your event.</span></h2>
          <p class="lede">Tell us what you’re planning, and we’ll help match the female DJ entertainment, production, and energy to the moment.</p>
        </div>
        <a href={site.calendly} target="_blank" rel="noopener" class="btn btn-primary btn-lg exp-cta-btn">Schedule a Free Consultation <span class="arrow">→</span></a>
      </div>
    </div>
  </section>

  <section class="section tight awards-band">
    <Marquee items={awards} speed={28} />
  </section>
</Base>

<style>
  .svc-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 1.2rem; }
  @media (max-width: 640px) { .svc-grid { grid-template-columns: 1fr; } }

  .sec-head { display: flex; align-items: flex-end; justify-content: space-between; gap: 1.5rem; margin-bottom: clamp(2rem, 1.5rem + 2vw, 3rem); }
  .sec-head > div { display: grid; gap: 0.9rem; max-width: 62ch; }
  .sec-head-link { padding-bottom: 0.4rem; white-space: nowrap; }
  @media (max-width: 700px) { .sec-head { flex-direction: column; align-items: flex-start; } }

  /* Category deep-dive media */
  .exp-cat { scroll-margin-top: 90px; }
  .exp-media { display: grid; grid-template-columns: 1fr 1fr; gap: clamp(1.1rem, 0.8rem + 1.5vw, 1.8rem); align-items: start; }
  .exp-videos { display: grid; gap: 1rem; align-content: start; }
  .exp-photos { display: grid; grid-template-columns: 1fr 1fr; gap: 0.9rem; }
  .exp-fig { display: grid; gap: 0.45rem; }
  .exp-cap { font-size: 0.85rem; color: var(--text-mute); line-height: 1.4; }
  @media (max-width: 820px) {
    .exp-media { grid-template-columns: 1fr; }
  }

  .proc-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 1.1rem; }
  .proc { padding: 1.8rem 1.5rem; display: grid; gap: 0.6rem; align-content: start; }
  .proc-n { font-family: var(--font-display); font-weight: 700; font-size: 2rem; letter-spacing: -0.03em; }
  .proc-t { font-family: var(--font-display); font-size: 1.2rem; font-weight: 600; }
  .proc-d { color: var(--cream-dim); font-size: 0.93rem; }
  @media (max-width: 820px) { .proc-grid { grid-template-columns: 1fr 1fr; } }
  @media (max-width: 480px) { .proc-grid { grid-template-columns: 1fr; } }

  .types { display: flex; flex-wrap: wrap; gap: 0.6rem; justify-content: center; max-width: 880px; margin: 1.6rem auto 0; }
  .type-chip { font-size: 0.92rem; padding: 0.6em 1.1em; }

  /* Full-width CTA bar */
  .exp-cta-bar {
    position: relative;
    display: grid;
    grid-template-columns: 1.5fr auto;
    gap: clamp(1.5rem, 1rem + 3vw, 3.5rem);
    align-items: center;
    padding: clamp(2rem, 1.4rem + 3vw, 3.6rem);
    border-radius: calc(var(--radius) + 8px);
    background: var(--grad);
    overflow: hidden;
    isolation: isolate;
    box-shadow: 0 40px 80px -40px rgba(123, 47, 247, 0.55);
  }
  .exp-cta-glow { width: 55%; height: 130%; top: -15%; right: -8%; background: radial-gradient(circle, rgba(255,255,255,0.4), transparent 65%); opacity: 0.5; filter: blur(60px); }
  .exp-cta-text { position: relative; z-index: 1; display: grid; gap: 0.8rem; max-width: 46ch; }
  .exp-cta-text .kicker, .exp-cta-text .h2 { color: #fff; }
  .exp-cta-text .lede { color: rgba(255,255,255,0.9); }
  .exp-cta-btn { position: relative; z-index: 1; background: #fff; color: var(--violet); }
  @media (max-width: 760px) { .exp-cta-bar { grid-template-columns: 1fr; } }

  .awards-band { border-top: 1px solid var(--line); }
</style>
